nditions"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Procédure"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Bonne conduite"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"• Respect des conditions pendant au moins la moitié de la durée • Reclassement acquis • Surveillance non nécessaire"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Demande de la personne ou décision d'office du JAP"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Suspension temporaire"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Motifs familiaux, médicaux, sociaux ou professionnels justifiés"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Demande motivée au JAP"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Conversion en sursis probatoire"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Mesure plus adaptée à la situation"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Décision du JAP après débat contradictoire"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Motifs médicaux graves"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Incompatibilité médicale prouvée avec le dispositif"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Certificat médical + décision du JAP"}]}]}]}]},{"type":"paragraph"},{"type":"horizontalRule"},{"type":"paragraph"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Avantages et inconvénients par rapport à la détention classique"},{"type":"text","text":"\n"}]},{"type":"paragraph","content":[{"type":"text","text":"Le tableau comparatif ci-dessous permet de mieux comprendre les différences entre la DDSE et l'incarcération traditionnelle :"}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Caractéristique"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Détention classique"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Détention domiciliaire sous surveillance électronique"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Lieu d'exécution"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Établissement pénitentiaire"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Domicile ou lieu d'hébergement désigné"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Liberté de mouvement"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Très restreinte, limitée à l'enceinte de la prison"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Restreinte au domicile avec possibilité de sorties autorisées"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Liens sociaux"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Contact limité (visites, téléphone, courrier)"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Maintien des relations familiales quotidiennes"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Activité professionnelle"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Généralement interrompue ou très limitée"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Peut être maintenue selon les horaires autorisés"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Réinsertion sociale"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Plus difficile, rupture avec l'environnement"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Facilitée, maintien dans le tissu social"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Coût pour l'État"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Environ 110€/jour/détenu"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Environ 30€/jour/personne"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Surveillance"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Directe par le personnel pénitentiaire"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Électronique à distance"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Impact psychologique"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Choc carcéral, promiscuité, isolement"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Stress lié à la surveillance, sentiment d'intrusion"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Stigmatisation"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Forte après la sortie de prison"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Limitée, plus discrète durant l'exécution"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Risque d'influences négatives"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Exposition au milieu carcéral"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Très limité, reste dans son environnement habituel"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Taux de récidive observé"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Plus élevé pour les courtes peines"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Généralement plus faible"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Personnalisation"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Limitée aux aménagements internes"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Forte adaptation aux contraintes individuelles"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Questions éthiques"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Conditions de détention, surpopulation"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Vie privée, contrôle constant, intrusion"}]}]}]}]},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Questions fréquentes sur la DDSE"},{"type":"text","text":"\n"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"La DDSE est-elle applicable aux mineurs ?"}]},{"type":"paragraph","content":[{"type":"text","text":"Oui, la DDSE en tant que peine autonome est applicable aux mineurs de plus de 13 ans, avec des adaptations liées au "},{"type":"text","text":"Code de justice pénale des mineurs","marks":[{"type":"link","attrs":{"href":"https://www.legifrance.gouv.fr/codes/texte_lc/LEGITEXT000039086952/"}},{"type":"underline"}]},{"type":"text","text":"."},{"type":"text","text":"\n"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Puis-je choisir de porter le bracelet au poignet plutôt qu'à la cheville ?"}]},{"type":"paragraph","content":[{"type":"text","text":"En principe, le bracelet est posé à la cheville, mais pour des raisons médicales ou professionnelles justifiées, il peut être fixé au poignet."},{"type":"text","text":"\n"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Est-il possible de prendre une douche ou de nager avec le bracelet ?"}]},{"type":"paragraph","content":[{"type":"text","text":"Le bracelet est étanche et résistant, permettant de prendre une douche. Cependant, la baignade prolongée (piscine, mer) est généralement déconseillée."},{"type":"text","text":"\n"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Comment fonctionne le bracelet lors des déplacements professionnels ?"}]},{"type":"paragraph","content":[{"type":"text","text":"Les déplacements professionnels réguliers sont intégrés dans les horaires autorisés. Pour les déplacements exceptionnels, une autorisation spécifique doit être demandée au SPIP."},{"type":"text","text":"\n"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Que se passe-t-il en cas de coupure d'électricité au domicile ?"}]},{"type":"paragraph","content":[{"type":"text","text":"Le boîtier récepteur dispose généralement d'une batterie de secours. En cas de coupure prolongée, il est recommandé de contacter rapidement le SPIP."},{"type":"text","text":"\n"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Le bracelet électronique est-il visible sous les vêtements ?"}]},{"type":"paragraph","content":[{"type":"text","text":"Le bracelet est relativement discret mais peut être visible selon le type de vêtements portés. Il n'existe pas d'obligation légale de le cacher."}]},{"type":"paragraph"},{"type":"horizontalRule"},{"type":"paragraph"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"Besoin d'une défense pénale adaptée ?"}]},{"type":"paragraph","content":[{"type":"text","text":"\n"},{"type":"text","text":"Si vous ou l'un de vos proches êtes concerné par une mesure de DDSE ou souhaitez savoir si vous pourriez en bénéficier, n'hésitez pas à "},{"type":"text","text":"contacter le cabinet Plouton","marks":[{"type":"link","attrs":{"href":"https://www.jplouton-avocat.fr/notre-cabinet"}},{"type":"underline"}]},{"type":"text","text":"."},{"type":"text","text":"\n"}]},{"type":"paragraph","content":[{"type":"text","text":"Cabinet Plouton, constitué d'avocats pénalistes expérimentés, pourra vous accompagner dans toutes les étapes :"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Demander la DDSE comme peine principale ou comme aménagement"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Vous aider à réunir les conditions nécessaires"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Vous conseiller sur vos droits et obligations"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Vous assister en cas de difficultés dans l'exécution de la mesure"},{"type":"text","text":"\n"}]}]}]},{"type":"paragraph","content":[{"type":"text","text":"Bénéficiez d'une "},{"type":"text","text":"stratégie de défense","marks":[{"type":"link","attrs":{"href":"https://www.jplouton-avocat.fr/d%C3%A9fense-p%C3%A9nale/droit-p%C3%A9nal"}},{"type":"underline"}]},{"type":"text","text":" personnalisée et d'un accompagnement juridique de qualité pour traverser cette période."}]},{"type":"paragraph"},{"type":"horizontalRule"},{"type":"paragraph"},{"type":"paragraph","content":[{"type":"text","text":"Article rédigé par Me Julien Plouton, avocat au Barreau de Bordeaux spécialisé en droit pénal. Les informations contenues dans cet article sont d'ordre général et ne sauraient constituer un avis juridique personnalisé. Pour toute question spécifique, "},{"type":"text","text":"veuillez consulter un professionnel du droit.","marks":[{"type":"link","attrs":{"href":"https://www.jplouton-avocat.fr"}},{"type":"underline"}]},{"type":"text","text":"\n"}]},{"type":"paragraph","content":[{"type":"text","text":"Dernière mise à jour : mars 2025"}]}]}
