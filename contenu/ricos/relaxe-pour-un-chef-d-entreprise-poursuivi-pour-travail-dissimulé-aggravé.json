          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ", et ",
              "decorations": [
                {
                  "type": "COLOR",
                  "colorData": {
                    "foreground": "#17475E"
                  }
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "emploi d’un étranger non muni d’une autorisation de travail",
              "decorations": [
