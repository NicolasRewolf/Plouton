          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "La Cour d'appel de Bordeaux, par un arrêt du 16 mai 2017, a fait droit à nos arguments et a infirmé la décision du Tribunal correctionnel.",
