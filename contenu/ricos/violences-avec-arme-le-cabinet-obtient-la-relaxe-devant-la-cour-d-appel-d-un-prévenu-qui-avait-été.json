          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Le Tribunal correctionnel de Bordeaux, le 16 septembre 2016, a déclaré Monsieur A coupable des faits reprochés. Il l'a condamné à :",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
