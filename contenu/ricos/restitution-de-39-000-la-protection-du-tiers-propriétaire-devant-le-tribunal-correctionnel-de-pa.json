            }
          }
        ],
        "headingData": {
          "level": 2
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "2qce47ahaq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Cette affaire illustre plusieurs principes essentiels du droit pénal patrimonial.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
