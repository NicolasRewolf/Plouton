          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Conclusion",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "5plbj5skhg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "L'abandon des poursuites du chef de blanchiment et la restitution des 39 000 euros saisis rappellent qu'en matière pénale, la rigueur probatoire et le respect des droits fondamentaux demeurent essentiels, y compris lorsqu'il s'agit de tiers à la procédure.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
