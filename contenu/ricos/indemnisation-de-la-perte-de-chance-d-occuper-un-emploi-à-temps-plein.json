            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Les faits : un accident corporel et une liquidation contestée",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "219uhuajsa",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
