            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "La Cour d'appel a confirmé en tous points la décision du Pôle social et retenu sa propre compétence pour majorer à son montant maximal les rentes allouées à l'épouse et aux enfants de Monsieur H.",
              "decorations": []
            }
