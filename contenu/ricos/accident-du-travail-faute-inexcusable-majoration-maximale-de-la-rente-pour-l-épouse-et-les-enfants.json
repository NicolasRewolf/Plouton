        "id": "p8ytwy3tgq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "La juridiction a accordé à Madame H. et à ses enfants la majoration maximale de la rente.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
