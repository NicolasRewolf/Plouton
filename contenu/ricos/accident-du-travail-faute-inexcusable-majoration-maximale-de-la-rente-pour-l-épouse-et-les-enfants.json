                "id": "badlri6ada",
                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "Le fait que l'employeur avait été relaxé par le Tribunal correctionnel du chef d'homicide involontaire, ce qui devait, selon les appelants, faire obstacle à la reconnaissance d'une faute inexcusable.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
