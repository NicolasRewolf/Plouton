        "paragraphData": {}
      },
      {
        "type": "HEADING",
        "id": "zit0l5wleg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "La reconnaissance de la faute inexcusable par le Pôle social le 27 octobre 2021",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "kgqv1zyjha",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Parallèlement à la procédure devant le Tribunal correctionnel, le cabinet avait saisi le Pôle social d'une demande de reconnaissance de la faute inexcusable de l'employeur. L'argument central : aucun dispositif ne permettait de sécuriser les abords d'une trémie ouverte sur un vide de grande hauteur, placée sur une toiture, au travers de laquelle Monsieur H. avait mortellement chuté.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "qnsi5gpoxg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "lpls6weq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "L'enjeu était d'obtenir la majoration de la rente allouée à Madame H. et à ses enfants.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "rhlc1nggw",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
