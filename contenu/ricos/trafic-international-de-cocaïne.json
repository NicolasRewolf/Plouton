        "id": "jqpc7qmoaw",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Moins de 24 heures plus tard, les policiers ont interpellé Khalid B. dans son restaurant. Sid Hamed B. a été arrêté peu après. La « mule », elle, a d'abord quitté la France pour la Turquie avant d'être arrêtée quelques jours plus tard.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
