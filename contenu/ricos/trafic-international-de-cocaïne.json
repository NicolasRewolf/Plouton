          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "L'enquête de la brigade des stupéfiants de la Direction interrégionale de la Police judiciaire de Bordeaux a débuté à la fin de 2009 sur renseignement anonyme. Les investigations ont rapidement révélé le fonctionnement du réseau : Khalid B. s'approvisionnait en Belgique et livrait la cocaïne à Bordeaux via Sid Hamed B.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "wcuqd3bkwa",
        "nodes": [
          {
