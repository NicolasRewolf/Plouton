      },
      {
        "type": "PARAGRAPH",
        "id": "nor2psyuug",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "L'année 2016 apparaissait ainsi comme « une date magique ». Elle correspondait précisément à la période de prévention retenue par le parquet et le magistrat instructeur avant même que l'expert n'ait été missionné.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
