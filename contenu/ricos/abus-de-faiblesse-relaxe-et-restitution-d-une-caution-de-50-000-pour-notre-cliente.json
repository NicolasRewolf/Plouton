                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "Premier rapport :",
                      "decorations": [
                        {
                          "type": "BOLD"
                        }
                      ]
                    }
                  },
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": " altération de l'état général sur le plan physique, mais sur le plan psychique la patiente n'était pas confuse et conservait une bonne maîtrise verbale.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
          {
            "type": "LIST_ITEM",
            "id": "tkq6yecna",
            "nodes": [
              {
                "type": "PARAGRAPH",
