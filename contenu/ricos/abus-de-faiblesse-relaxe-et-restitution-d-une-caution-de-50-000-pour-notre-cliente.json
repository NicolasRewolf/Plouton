        "id": "npbbifatjg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Cette ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "conclusion était pour le moins surprenante pour la défense",
              "decorations": [
                {
                  "type": "BOLD"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ". Elle ne reposait sur aucun élément médico-légal. L'expert indiquait par ailleurs quelques lignes plus tôt qu'il était très difficile de situer le début d'apparition de ces troubles.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
