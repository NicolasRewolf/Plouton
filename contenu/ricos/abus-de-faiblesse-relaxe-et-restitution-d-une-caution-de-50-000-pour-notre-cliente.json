                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "Second rapport",
                      "decorations": [
                        {
                          "type": "BOLD"
                        }
                      ]
                    }
                  },
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": " (quelques mois plus tard, après séparation de la patiente d'avec son amie et placement dans un service de protection) : troubles de la mémoire pour les faits récents, troubles du caractère avec perte de sociabilité.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
