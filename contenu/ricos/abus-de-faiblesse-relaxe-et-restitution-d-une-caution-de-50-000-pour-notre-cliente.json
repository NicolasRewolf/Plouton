            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "L'expert concluait alors que le tableau général évoquait une détérioration mentale débutante, qui pouvait avoir débuté en 2016.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
