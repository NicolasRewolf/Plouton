        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Les faits : une amitié intergénérationnelle requalifiée en abus de faiblesse",
              "decorations": []
            }
          }
        ],
        "headingData": {
