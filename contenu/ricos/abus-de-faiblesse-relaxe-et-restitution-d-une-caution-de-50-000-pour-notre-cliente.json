                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "d'autres précisaient au contraire qu'elle leur avait semblé parfaitement alerte et consciente de ses actes et de ses engagements, soulignant par ailleurs son tempérament autoritaire.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          }
        ],
        "bulletedListData": {
