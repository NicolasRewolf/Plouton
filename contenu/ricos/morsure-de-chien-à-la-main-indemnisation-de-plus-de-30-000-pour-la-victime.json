                      "text": "De troubles de la sensibilité distale et de douleurs articulaires",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
          {
            "type": "LIST_ITEM",
            "id": "qecpt5055",
            "nodes": [
              {
                "type": "PARAGRAPH",
                "id": "3dt5y5056",
                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "De légères manifestations d’anxiété",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
