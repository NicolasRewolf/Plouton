                      "text": "D’un raccourcissement d’un millimètre de doigt",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
          {
            "type": "LIST_ITEM",
            "id": "2rgsn5052",
