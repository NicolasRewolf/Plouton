          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Droit pénal des affaires — Carrousel de TVA — Escroquerie en bande organisée et association de malfaiteurs — Mandat d'arrêt européen — Nullité de la citation.",
              "decorations": [
                {
                  "type": "ITALIC"
                }
              ]
            }
          }
        ],
        "paragraphData": {}
