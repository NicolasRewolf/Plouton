                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "plus de 6 millions d'euros de dommages et intérêts, solidairement, au bénéfice de l'État français.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          }
        ],
        "bulletedListData": {
          "indentation": 0.0
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "m7trurvxow",
        "nodes": [
          {
            "type": "TEXT",
