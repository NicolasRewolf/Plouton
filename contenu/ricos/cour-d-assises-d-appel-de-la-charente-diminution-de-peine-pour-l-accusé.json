        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "La décision rendue reconnaît à notre client des ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "circonstances atténuantes",
              "decorations": [
                {
                  "type": "BOLD"
                },
                {
                  "type": "LINK",
                  "linkData": {
                    "link": {
                      "url": "https://www.jplouton-avocat.fr/defense-penale/proces-criminel",
