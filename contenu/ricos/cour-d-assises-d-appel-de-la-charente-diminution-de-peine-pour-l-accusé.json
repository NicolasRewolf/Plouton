        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "L'enjeu de ce procès en appel s'annonçait particulièrement lourd. En première instance, l'accusé avait été condamné à ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "15 années de réclusion criminelle",
              "decorations": [
                {
                  "type": "BOLD"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " pour des faits de viol.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "o0mffvkna",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
