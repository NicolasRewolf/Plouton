        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "oggfccsbpw",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Notre espérance, en tant que défenseurs, est que cet arrêt permettra à cet homme encore jeune — privé de liberté depuis déjà quatre ans au moment du procès — de mieux accepter sa condamnation.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "b0mf5py68w",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "njenpkdfeg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Comprendre et vivre sa peine avec le sentiment d'avoir payé le juste prix de sa dette à la société est une étape indispensable. C'est la condition ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "sine qua non",
              "decorations": [
                {
                  "type": "ITALIC"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " pour qu'il puisse, un jour, reprendre le cours de sa vie en homme libre et apaisé, ce qui demeure, ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "in fine",
              "decorations": [
                {
                  "type": "ITALIC"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ", dans l'intérêt de tous.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
