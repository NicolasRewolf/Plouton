        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Défendre sans dénier le statut de la victime",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2.0
        }
      },
      {
        "style": {},
        "blockquoteData": {
