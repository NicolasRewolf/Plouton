            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " pour des faits de viol commis en état de récidive criminelle. La déclaration de culpabilité est maintenue, mais la juridiction a retenu des circonstances atténuantes, aboutissant à une peine plus individualisée.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
