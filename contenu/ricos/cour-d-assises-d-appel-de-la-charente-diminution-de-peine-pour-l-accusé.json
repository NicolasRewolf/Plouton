            "nodes": [
              {
                "type": "TEXT",
                "id": "",
                "nodes": [],
                "textData": {
                  "text": "Défendre l’accusé sans dénier à la partie civile son statut de victime : tel était l’enjeu fondamental et la ligne directrice de ce procès.",
                  "decorations": [
                    {
                      "type": "COLOR",
                      "colorData": {
                        "background": "rgba(0, 0, 0, 0)",
                        "foreground": "#17475E"
                      }
                    },
