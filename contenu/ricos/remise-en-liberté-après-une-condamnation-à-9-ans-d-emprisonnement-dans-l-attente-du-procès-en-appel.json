              "text": " ",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "HEADING",
        "id": "cuqbpnuhva",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "La décision : remise en liberté",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2.0
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "51p7z97ga",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "À l'issue de l'audience, la Chambre de l'Instruction a ordonné la remise en liberté de Monsieur L. Il préparera son procès en appel libre, sous les obligations qui pourront être fixées par la juridiction.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "tdbtquiqja",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "mia6xvhe1a",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Cette décision rappelle un principe essentiel de la procédure pénale française : une condamnation en première instance n'éteint pas la présomption d'innocence lorsqu'un appel est formé. La détention dans l'attente du procès en appel doit rester l'exception, justifiée par des nécessités précises, et non la simple conséquence automatique d'une première décision.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "xfwrrbd0sa",
        "nodes": [
