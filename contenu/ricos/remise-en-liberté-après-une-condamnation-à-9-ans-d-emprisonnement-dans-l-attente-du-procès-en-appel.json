        "nodes": [
          {
            "type": "LIST_ITEM",
            "id": "ifxr3n1uha",
            "nodes": [
              {
                "type": "PARAGRAPH",
                "id": "irqxrgdxda",
                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "Les garanties de représentation",
                      "decorations": [
                        {
                          "type": "BOLD"
                        }
                      ]
                    }
                  },
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": " : domicile stable, situation personnelle vérifiable, absence de risque de fuite.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
          {
            "type": "LIST_ITEM",
            "id": "wlilpaxexg",
            "nodes": [
              {
                "type": "PARAGRAPH",
                "id": "fuwyyqsdvg",
                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "La reconversion professionnelle",
                      "decorations": [
                        {
                          "type": "BOLD"
                        }
                      ]
                    }
                  },
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": " du client, qui avait par ailleurs été placé sous contrôle judiciaire pendant 5 ans avant le procès en première instance, sans incident.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          }
        ],
        "bulletedListData": {
          "indentation": 0.0
        }
      },
      {
        "type": "PARAGRAPH",
