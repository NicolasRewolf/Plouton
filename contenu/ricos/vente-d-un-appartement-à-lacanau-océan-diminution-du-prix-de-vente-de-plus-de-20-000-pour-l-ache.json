            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Les faits : un appartement acheté 167 000 € à Lacanau Océan",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2.0
        }
      },
      {
