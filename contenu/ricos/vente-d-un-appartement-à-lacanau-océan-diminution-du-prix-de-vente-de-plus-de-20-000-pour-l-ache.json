        "id": "9bbqvc6yrq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Cet écart, supérieur au seuil légal du vingtième, ouvrait droit à l'application de l'article 46 de la loi du 10 juillet 1965 et à une diminution proportionnelle du prix.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
