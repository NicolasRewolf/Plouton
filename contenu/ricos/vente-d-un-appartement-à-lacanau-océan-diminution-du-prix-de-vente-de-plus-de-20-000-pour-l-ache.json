            "nodes": [],
            "textData": {
              "text": "Le 5 décembre 2018, le Tribunal de Grande Instance de Bordeaux a condamné solidairement les vendeurs et leur agence immobilière à indemniser les acheteurs.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
