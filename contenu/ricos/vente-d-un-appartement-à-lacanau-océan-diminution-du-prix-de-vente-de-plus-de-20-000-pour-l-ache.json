            "id": "",
            "nodes": [],
            "textData": {
              "text": "Le fondement juridique : l'article 46 de la loi du 10 juillet 1965",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2.0
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "ok8tuhic1g",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
