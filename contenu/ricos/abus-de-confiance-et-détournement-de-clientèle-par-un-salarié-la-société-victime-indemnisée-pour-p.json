          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Le cabinet représentait une société spécialisée dans la vente et l'installation de matériel de sécurité incendie.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
