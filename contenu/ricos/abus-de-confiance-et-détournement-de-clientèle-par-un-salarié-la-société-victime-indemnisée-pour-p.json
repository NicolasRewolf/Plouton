        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "En 2015, Monsieur D. a présenté sa démission. Convoqué pour restituer le matériel professionnel en sa possession, il a nié en disposer.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "m8qlfdekmg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
