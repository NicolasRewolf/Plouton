        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Intervenus rapidement sur place, les policiers constataient la présence au sol du tenancier du bar. Ce dernier s'était vu porter plusieurs coups de couteau : un au niveau du ventre et l'autre au thorax. L'incapacité totale de travail constatée était de 21 jours.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
