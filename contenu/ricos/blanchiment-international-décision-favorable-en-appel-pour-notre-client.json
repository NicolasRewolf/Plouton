        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Concernant l'action civile, la Cour d'Appel a déclaré irrecevables les conclusions de plusieurs parties civiles, réduisant ainsi substantiellement les condamnations civiles dont il avait fait l'objet par le Tribunal correctionnel.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {
