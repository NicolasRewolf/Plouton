            "textData": {
              "text": "Agression à Bordeaux : 13 000 € d’indemnisation après l’attaque d’un client par un agent de sécurité d’une discothèque",
              "decorations": [
                {
                  "type": "BOLD",
                  "fontWeightValue": 700.0
                }
              ]
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "0u197383",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "En septembre 2022, le Tribunal correctionnel de Bordeaux a condamné un agent de sécurité et la société gestionnaire d’une célèbre discothèque du quai de Paludate à verser près de 13 000 € d’indemnités à un client violemment agressé en 2018.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {
          "textStyle": {
            "textAlignment": "AUTO"
          }
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "o211h549",
        "nodes": [],
        "paragraphData": {}
      },
