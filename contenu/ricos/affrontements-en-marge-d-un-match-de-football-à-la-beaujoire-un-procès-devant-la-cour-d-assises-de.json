        "type": "PARAGRAPH"
      },
      {
        "paragraphData": {
          "textStyle": {
            "textAlignment": "JUSTIFY"
          }
        },
        "style": {},
        "id": "1ed6e3325",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "L’enjeu consistera notamment, lors du procès devant la Cour d’assises, à replacer les faits dans leur contexte exact, à analyser les circonstances de l’affrontement et à discuter l’existence ou non d’une intention homicide.",
              "decorations": [
                {
                  "type": "COLOR",
                  "colorData": {
                    "foreground": "#14495B"
                  }
                }
              ]
            }
          }
        ],
        "type": "PARAGRAPH"
      },
      {
        "paragraphData": {
          "textStyle": {
            "textAlignment": "JUSTIFY"
          }
        },
        "style": {},
        "id": "6l9p73327",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
              "decorations": [
                {
                  "type": "COLOR",
                  "colorData": {
                    "foreground": "#14495B"
                  }
                }
