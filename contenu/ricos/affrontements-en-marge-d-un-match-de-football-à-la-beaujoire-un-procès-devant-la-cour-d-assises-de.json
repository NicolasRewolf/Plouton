        "id": "5vjb93291",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "L’enquête met également en lumière le rôle d’un second chauffeur VTC, poursuivi notamment pour violences et destruction de preuves après la disparition d’enregistrements vidéo issus de son véhicule, qui a finalement accepté, le 11 mars dernier la peine proposée lors d’une comparution sur reconnaissance préalable de culpabilité.",
              "decorations": [
                {
                  "type": "COLOR",
                  "colorData": {
                    "foreground": "#14495B"
                  }
                }
              ]
            }
          }
        ],
        "type": "PARAGRAPH"
