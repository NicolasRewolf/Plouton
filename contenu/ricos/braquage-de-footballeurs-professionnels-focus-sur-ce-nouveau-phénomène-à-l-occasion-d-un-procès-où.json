        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Les faits s'étaient déroulés dans le courant de l'année 2016 et avaient été commis par 5 jeunes gens issus du quartier des Aubiers pour un préjudice de plus de 134.000 euros.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "v2cktflw4w",
        "nodes": [
