        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Le footballeur tend ainsi de plus en plus à devenir le symbole, aux yeux de certains, de l'argent facile et pas nécessairement mérité.",
