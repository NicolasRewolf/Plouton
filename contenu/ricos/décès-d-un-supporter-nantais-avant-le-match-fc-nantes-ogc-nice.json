          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ". Qu'un tel drame puisse se produire à l'occasion d'un match de football qui par essence est une fête, nous interroge tous. Nous ne pouvons que faire nôtres les mots de ",
              "decorations": []
