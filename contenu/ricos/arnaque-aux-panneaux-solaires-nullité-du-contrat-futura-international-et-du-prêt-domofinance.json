                  "type": "BOLD",
                  "fontWeightValue": 700
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " et l'obligation de résultat sur la mise en service du matériel : un système photovoltaïque qui ne peut être raccordé, qui présente des risques d'incendie ou qui ne produit pas l'énergie promise constitue un manquement contractuel grave susceptible d'entraîner la résolution judiciaire du contrat.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {
          "textStyle": {
            "textAlignment": "AUTO"
