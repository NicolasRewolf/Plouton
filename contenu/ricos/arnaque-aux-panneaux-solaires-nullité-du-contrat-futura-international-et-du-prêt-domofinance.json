          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Le même jour, ils acceptaient une offre de crédit d'un montant identique de 24 600 euros émise par la société DOMOFINANCE, partenaire financier de l'opération.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {
