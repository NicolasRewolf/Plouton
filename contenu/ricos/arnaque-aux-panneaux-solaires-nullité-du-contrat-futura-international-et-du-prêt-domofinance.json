          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "La méconnaissance de ces exigences, comme les manquements substantiels à l'obligation principale du contrat, ouvrent la voie à la nullité ou à la résolution. S'ajoute, en matière d'installation, l'",
              "decorations": []
