        "id": "xcpwo696",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Lorsque le bien ou la prestation est financé par un crédit dédié — c'est-à-dire un crédit dont le contrat mentionne expressément le bien financé — il s'agit d'un ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "crédit affecté",
              "decorations": [
