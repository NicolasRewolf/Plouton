        }
      },
      {
        "type": "PARAGRAPH",
        "id": "9gqfoxe8eg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Dès l'examen du dossier, notre cabinet a relevé plusieurs difficultés juridiques majeures liées à la régularité de la procédure.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "pz2o8dsolw",
        "nodes": [
          {
            "type": "TEXT",
