                "id": "327ec2voha",
                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "qu'elle a, en sa qualité de partie civile revendiquée, personnellement subi un préjudice ;",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
          {
            "type": "LIST_ITEM",
            "id": "qpaolfyoqg",
            "nodes": [
              {
                "type": "PARAGRAPH",
                "id": "cp6kreid3a",
                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "que ce préjudice est directement causé par l'infraction invoquée.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          }
        ],
        "bulletedListData": {
          "indentation": 0
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "z8glbrwryq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
