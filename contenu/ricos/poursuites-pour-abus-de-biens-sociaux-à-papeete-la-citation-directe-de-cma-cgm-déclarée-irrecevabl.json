        "id": "yibbliej7q",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Si vous êtes confronté à une procédure pénale ou à une citation directe, notre cabinet peut vous accompagner dans l'analyse du dossier et la défense de vos intérêts.",
              "decorations": []
            }
          }
        ],
