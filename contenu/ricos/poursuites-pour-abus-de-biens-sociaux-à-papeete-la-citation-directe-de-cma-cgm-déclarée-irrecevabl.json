        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "À défaut, la citation directe est irrecevable et l'action publique n'est pas régulièrement engagée.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
