          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "La citation directe délivrée par la filiale du groupe CMA CGM était dépourvue de clarté à plusieurs égards :",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "gb9hybpiyg",
        "nodes": [
