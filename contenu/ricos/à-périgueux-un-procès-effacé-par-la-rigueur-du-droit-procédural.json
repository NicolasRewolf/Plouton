        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Un délai est sollicité afin de préparer sa défense. Monsieur D. est placé en détention provisoire dans l'attente de l'audience, puis ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "saisit le Cabinet",
