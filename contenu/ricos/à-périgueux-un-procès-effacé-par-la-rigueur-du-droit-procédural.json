        "id": "majrdkfvwq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Pour procéder à un contrôle d'identité, les policiers doivent respecter un cadre légal précis prévu par ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "les articles 78-1 à 78-7 du Code de procédure pénale",
              "decorations": [
                {
                  "type": "LINK",
                  "linkData": {
                    "link": {
                      "url": "https://www.legifrance.gouv.fr/codes/id/LEGISCTA000006151880/",
                      "target": "BLANK",
                      "rel": {
                        "nofollow": false,
                        "sponsored": false,
                        "ugc": false
                      }
                    }
                  }
                },
                {
                  "type": "UNDERLINE",
                  "underlineData": true
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ". Ces dispositions prévoient quatre types de contrôles :",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "mwv507nxzw",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
