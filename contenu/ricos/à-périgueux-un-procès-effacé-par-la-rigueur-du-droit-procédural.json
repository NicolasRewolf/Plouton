            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ". La procédure n'ayant pas été respectée, notre client a été relaxé et remis en liberté à l'issue de l'audience, après un mois passé en détention provisoire.",
              "decorations": []
            }
          }
