                "id": "uvev05gfkw",
                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "le contrôle d'identité de police judiciaire, lorsqu'il existe des raisons plausibles de croire à la commission d'une infraction flagrante ;",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
          {
            "type": "LIST_ITEM",
            "id": "eivbi17g",
            "nodes": [
