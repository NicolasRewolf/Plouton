      },
      {
        "type": "PARAGRAPH",
        "id": "i6qiz7dgfq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Monsieur D. est ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "in fine",
              "decorations": [
