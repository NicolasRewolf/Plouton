                "id": "hkjwdijfw",
                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "le contrôle d'identité de police administrative, pour prévenir une atteinte à l'ordre public, notamment liée à la sécurité des personnes et des biens ;",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
          {
            "type": "LIST_ITEM",
            "id": "gxepitpqba",
