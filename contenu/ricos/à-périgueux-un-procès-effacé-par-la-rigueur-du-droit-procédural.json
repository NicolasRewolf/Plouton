          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Le 8 janvier 2025, Monsieur D. est contrôlé par la police à bord d'un véhicule, en compagnie de deux de ses amis.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
