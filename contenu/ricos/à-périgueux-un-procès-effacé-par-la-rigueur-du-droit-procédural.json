                  "type": "ITALIC"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " renvoyé en comparution immédiate devant le Tribunal correctionnel de Périgueux des chefs de trafic de stupéfiants (offre, cession, détention et transport de produits stupéfiants).",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
