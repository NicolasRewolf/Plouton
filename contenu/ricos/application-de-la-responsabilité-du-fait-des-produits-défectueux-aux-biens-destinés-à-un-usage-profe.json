        "id": "caaykvtbqw",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Quand un produit défaillant cause un dommage à un bien utilisé pour le travail — un transformateur électrique, une machine industrielle, un équipement agricole — la victime se trouve face à un choix qui semble purement technique. Pourtant, ce choix commande l'issue de toute l'action en réparation : sur quel fondement agir ?",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "0vjh0amkaw",
        "nodes": [
          {
