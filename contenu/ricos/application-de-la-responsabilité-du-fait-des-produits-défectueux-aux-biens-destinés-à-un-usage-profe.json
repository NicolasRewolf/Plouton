          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Son principe est protecteur : le producteur est responsable du dommage causé par le défaut de son produit, c'est-à-dire d'un produit qui n'offre pas la sécurité à laquelle on peut légitimement s'attendre. La victime n'a pas à démontrer une faute. Elle doit seulement prouver trois éléments :",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
