          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "D'un côté, la ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "responsabilité du fait des produits défectueux",
              "decorations": [
                {
                  "type": "BOLD"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ", régime spécial issu du droit européen, soumis à une prescription courte de trois ans. De l'autre, la ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "responsabilité du fait des choses",
              "decorations": [
                {
                  "type": "BOLD"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ", régime de droit commun à la prescription plus longue. La tentation est forte, en cas d'expertise tardive ou de procédure ralentie, de se rabattre sur le second pour échapper aux délais du premier.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
