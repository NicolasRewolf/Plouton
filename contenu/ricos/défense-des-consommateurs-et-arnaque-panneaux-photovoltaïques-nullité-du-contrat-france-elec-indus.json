                {
                  "type": "ITALIC",
                  "italicData": true
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " janvier 2014 et que la TVA réduite à 5,5% n’a pas été appliquée par le commercial qui a appliqué une TVA à 10% sur le bon de commande.",
              "decorations": [
                {
                  "type": "ITALIC",
                  "italicData": true
