        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "A cela s’ajoute le fait que le crédit d’impôt promis par la société dans sa brochure commerciale a été supprimé le 1",
              "decorations": [
                {
                  "type": "ITALIC",
                  "italicData": true
