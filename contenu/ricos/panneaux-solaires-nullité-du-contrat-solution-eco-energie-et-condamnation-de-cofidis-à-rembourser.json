          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "L'installation se révèle défaillante. Monsieur W. découvre par ailleurs que le bon de commande ne respecte pas les mentions obligatoires imposées par le Code de la consommation en matière de démarchage hors établissement. Il engage alors une action en nullité contre le vendeur et la banque prêteuse.",
              "decorations": []
            }
