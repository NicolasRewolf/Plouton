                {
                  "type": "BOLD"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ". Cette pratique, souvent réalisée en méconnaissance des dispositions du Code de la consommation, a donné lieu à un contentieux de masse devant les juridictions françaises.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
