          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "L'affaire concerne Monsieur W., qui avait commandé au début de l'année 2014 une installation photovoltaïque lors d'un démarchage à domicile effectué par des commerciaux de la société ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "SOLUTION ECO ENERGIE",
