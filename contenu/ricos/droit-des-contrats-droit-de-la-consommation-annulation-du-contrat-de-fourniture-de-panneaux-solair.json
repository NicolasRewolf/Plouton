        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Mais le juge bordelais en a décidé autrement. Mi-avril, il a prononcé l'annulation du contrat conclu avec ENR Plus et, à sa suite, celle du contrat souscrit auprès de l'établissement bancaire.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
