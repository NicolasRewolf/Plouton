          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "La SARL ENR Plus n'était pas présente à l'audience qui s'est tenue en mars devant le tribunal d'instance de Bordeaux. Domiciliée à Maisons-Alfort (Val-de-Marne), la société affiche un numéro de téléphone qui ne lui est plus attribué.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "8hwj5rpfga",
