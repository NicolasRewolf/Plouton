        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Rassuré par un interlocuteur qui promet de s'occuper de tout, content de faire un geste pour l'environnement, séduit par les promesses de rentabilité, le couple signe un bon de commande ainsi qu'une offre de contrat de crédit à blanc. Sur ces documents ne figurent ni les modalités de remboursement du crédit, ni le TEG.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
