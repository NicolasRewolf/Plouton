        "id": "1dd3n2484",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "L'ouverture de ces procédures collectives permet d'analyser le parcours de l'entreprise avant les difficultés et d'identifier les circonstances et décisions du dirigeant qui ont pu conduire à la cessation des paiements.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {
          "textStyle": {
            "textAlignment": "AUTO"
          }
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "k7v362486",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Dans certains cas, des comportements fautifs apparaissent comme étant à l'origine des difficultés ou ayant contribué à leur aggravation. Ces fautes peuvent alors être sanctionnées de différentes manières : ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "sanctions patrimoniales, professionnelles et/ou pénales",
              "decorations": [
                {
                  "type": "LINK",
                  "linkData": {
                    "link": {
                      "url": "https://www.jplouton-avocat.fr/d%C3%A9fense-p%C3%A9nale/droit-p%C3%A9nal-des-affaires",
