            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "skqu4ijriq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Abdelkader C., 37 ans, et Stéphanie S., 31 ans, comparaissent depuis hier et jusqu'à vendredi devant la cour d'assises de la Gironde pour violences volontaires ayant entraîné la mort sans intention de la donner.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "dgmkqq4pta",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
