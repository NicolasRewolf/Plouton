        "id": "nplklv8hmw",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "D'entrée de jeu, le président Michel Regaldo Saint-Blancard a cherché à apporter de la clarté dans un dossier parfois confus.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
