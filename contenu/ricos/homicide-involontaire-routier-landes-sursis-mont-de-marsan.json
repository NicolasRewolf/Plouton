        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Homicide involontaire et blessures involontaires par conducteur : un accident aux conséquences irréversibles",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2,
          "textStyle": {
            "textAlignment": "AUTO"
          }
        }
      },
      {
        "paragraphData": {
          "textStyle": {
