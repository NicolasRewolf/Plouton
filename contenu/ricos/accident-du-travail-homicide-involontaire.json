              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ou de prudence imposée par la loi ou les règlements, laquelle violation avait causé la mort de Monsieur H.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
