          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "homicide involontaire",
              "decorations": [
                {
                  "type": "BOLD"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ", en raison de manquements caractérisés à leurs ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "obligations de sécurité",
