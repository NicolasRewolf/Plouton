        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Alors qu'il se trouvait seul sur le toit marchant en direction du matériel, Monsieur H. passait au travers d'une toile masquant un puits de jour non sécurisé par des garde-corps et des filets.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
