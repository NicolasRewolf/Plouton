        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Il s'agira également d'obtenir ultérieurement devant le Tribunal des Affaires de Sécurité Sociale, pour la veuve de Monsieur H. et ses enfants, la reconnaissance de la ",
              "decorations": []
            }
          },
