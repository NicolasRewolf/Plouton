        "id": "6hipexkbxg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "A l'issue de leur intervention, ces derniers n'avaient, de manière totalement incompréhensible, pas remis en place les dispositifs de sécurité. Cela constituait manifestement une violation d'une ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "obligation particulière de sécurité",
              "decorations": [
                {
