        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Le 26 juillet 2016, le chef d'équipe demandait à Monsieur H. de se rendre sur le toit du bâtiment afin d'y récupérer du matériel, lequel y était entreposé afin de se prémunir des vols.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
