        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Par ailleurs, l'employeur de Monsieur H. avait également manqué à son obligation de garantir la sécurité de ses salariés. Il avait omis de mettre en place des protections collectives contre les risques de chute de hauteur sur le chantier, manquement qui a causé la mort de Monsieur H.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "vzuxvwedua",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
