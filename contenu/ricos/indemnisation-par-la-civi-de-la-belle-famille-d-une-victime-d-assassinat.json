        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Les faits : un assassinat à Barsac jugé par la Cour d'assises de la Gironde",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2.0
        }
