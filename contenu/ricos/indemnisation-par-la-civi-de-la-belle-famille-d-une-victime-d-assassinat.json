        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "En tant que compagne de Monsieur B., Madame F. a sollicité la Commission pour obtenir une indemnisation plus large couvrant à la fois le préjudice d'affection et le préjudice économique.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
