        "id": "i5hmepzg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Monsieur C. licenciait finalement Melle V. pour inaptitude, en respectant scrupuleusement la procédure légale.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
