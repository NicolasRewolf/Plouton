                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "une attestation de son médecin traitant indiquant que son état de santé s'était dégradé à la suite des violences commises sur sa personne par son employeur ;",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
          {
            "type": "LIST_ITEM",
