        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "gpyhesv2cw",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Melle V. saisissait le Conseil de Prud'hommes (CPH) afin de contester le bien-fondé de son licenciement. Elle soutenait que son inaptitude résultait du comportement injurieux et violent de son employeur le jour de la reprise du travail. Elle sollicitait la condamnation de son employeur à lui verser plus de 42 000 € de dommages et intérêts.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "nflqm2vz2g",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "rqs5v07hfa",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "À l'appui de ses demandes, la salariée produisait deux pièces :",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "jacmnizmba",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
