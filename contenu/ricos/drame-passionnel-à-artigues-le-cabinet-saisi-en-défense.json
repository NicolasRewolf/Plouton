          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "zmqo4bccyg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "La police criminelle et le juge d'instruction devront déterminer si les faits relèvent d'un homicide involontaire ou d'un assassinat. Cette qualification pénale est déterminante : elle conditionne la juridiction de jugement et l'échelle des peines encourues.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
