            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "rqoz03l7vw",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Il était 6h30 quand les secours ont été appelés par les voisins, réveillés par les bruits de détonation. À leur arrivée, ils n'ont pu que constater le décès de la victime dans le hall de l'immeuble où elle résidait.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "utphqfleaq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "HEADING",
        "id": "tz45govhja",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Une reddition spontanée au commissariat de Cenon",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2.0
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "psuwwl5pcg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "m5h61o4xea",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "C'est de lui-même que l'homme s'est présenté au Commissariat de Cenon après les faits. Cette reddition spontanée constitue un élément important du dossier, susceptible d'être pris en compte dans l'appréciation des faits par les magistrats.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "nk8fts7ra",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
