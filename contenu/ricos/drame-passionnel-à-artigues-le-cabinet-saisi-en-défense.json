            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Homicide involontaire ou assassinat : la qualification en jeu",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2.0
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "xpfynkqmhq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
              "decorations": []
