        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "La défense de la gérante : déconstruire une présentation caricaturale",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2.0
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "dudqwbsbra",
        "nodes": [
          {
            "type": "TEXT",
