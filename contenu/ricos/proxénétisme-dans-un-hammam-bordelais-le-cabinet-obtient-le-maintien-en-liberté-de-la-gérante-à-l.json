            "nodes": [],
            "textData": {
              "text": "blanchiment",
              "decorations": [
                {
                  "type": "BOLD"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ". Au stade de l'enquête, il avait été mis en évidence qu'un certain nombre d'espèces leur avaient été remises par leurs parents et que des chèques des clients du Hammam avaient été déposés sur leurs comptes bancaires.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
