              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " et d'association de malfaiteurs. Le cabinet Plouton intervient en défense de l'un des principaux mis en examen.",
              "decorations": []
