        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Pourquoi supprimer la phase de conciliation préalable ?",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2
        }
      },
      {
