        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Certains témoins ont avancé l'hypothèse que l'accusé s'était fait « monter la tête » par ses camarades de chasse, à l'occasion d'un repas particulièrement alcoolisé la nuit des faits.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "c5h3w37m1q",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
