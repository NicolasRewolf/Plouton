        "id": "mbuejcqxg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Quant à l'",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "absence de mobile apparent",
              "decorations": [
                {
                  "type": "BOLD"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " également invoqué par la défense, c'est ignorer les mobiles internes propres à chaque homme, qui ne sont pas nécessairement portés à la connaissance de tiers. Ils peuvent également être masqués par la ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "« loi du silence »",
