        ],
        "headingData": {
          "level": 2.0
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "srzesyyfxa",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "La défense avait souligné que le ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "juge d'instruction",
              "decorations": [
                {
                  "type": "BOLD"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " chargé de l'enquête n'avait pas envisagé la culpabilité d'un tiers. Mais c'est précisément parce que toutes les pistes conduisaient à l'accusé.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
