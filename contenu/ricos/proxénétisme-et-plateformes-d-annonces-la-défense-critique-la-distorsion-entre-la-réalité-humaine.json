                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "Les plateformes numériques facilitent la diffusion des annonces, mais leur rôle économique demeure largement absent du débat pénal.",
