          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Monsieur Y., adulte handicapé pris en charge dans un foyer d'accueil médicalisé, est décédé en octobre 2009. La cause : une cardiopathie compliquée d'une infection généralisée.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "cdolqczrgg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
