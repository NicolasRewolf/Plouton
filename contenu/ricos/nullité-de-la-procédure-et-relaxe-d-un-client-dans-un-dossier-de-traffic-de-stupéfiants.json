        "id": "xyje20wjw",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Tribunal correctionnel de Bayonne, audience de comparution immédiate du 19 avril 2018.",
              "decorations": [
                {
                  "type": "ITALIC"
                }
              ]
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "axuvcziygq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
