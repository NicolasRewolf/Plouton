            "textData": {
              "text": ", obtient la nullité de la procédure et la relaxe de son client dans un dossier de trafic de stupéfiants, malgré des réquisitions de 4 ans ferme prises à son encontre.",
              "decorations": [
                {
                  "type": "BOLD"
                }
              ]
            }
          }
        ],
        "paragraphData": {}
      },
