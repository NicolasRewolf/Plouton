        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Les requérants décidaient alors d'assigner la société et la Banque aux fins de voir prononcer la résolution judiciaire du contrat de vente ainsi que du contrat de crédit affecté.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
