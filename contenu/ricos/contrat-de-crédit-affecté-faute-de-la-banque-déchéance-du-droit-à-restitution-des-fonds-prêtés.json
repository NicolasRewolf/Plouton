          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Suite à un démarchage à domicile, M. et Mme Y concluaient un contrat avec la société ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Nouvelle Régie des jonctions des énergies de France",
              "decorations": [
                {
                  "type": "ITALIC"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ", portant sur la fourniture et l'installation de panneaux photovoltaïques. L'opération était financée par un prêt d'un montant de 18 800 euros souscrit auprès de la Banque ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "SOLFEA",
              "decorations": [
                {
