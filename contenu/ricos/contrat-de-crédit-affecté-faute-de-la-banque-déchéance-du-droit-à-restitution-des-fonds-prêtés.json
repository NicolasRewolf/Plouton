        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "M. et Mme Y se rendaient peu à peu compte de la non-conformité de leur installation et du manquement aux dispositions relatives au démarchage à domicile.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
