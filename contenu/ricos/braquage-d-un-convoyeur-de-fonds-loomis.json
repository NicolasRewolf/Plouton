        "type": "HEADING",
        "id": "xmfrp6057",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Une expertise médico-légale sollicitée",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2.0,
          "textStyle": {
            "textAlignment": "AUTO"
          }
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "u48696059",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Nous avons également sollicité la réalisation d’une expertise médico-légale afin d’établir les conséquences et séquelles physiques et psychiques subies par notre client à la suite de cette agression.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {
