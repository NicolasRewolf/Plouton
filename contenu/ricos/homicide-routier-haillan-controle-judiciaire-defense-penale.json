          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Comme l'a relaté le journal Sud-Ouest, dans la nuit du 22 septembre 2025, vers 4 h 30 du matin, un drame de la route s'est produit au Haillan, en Gironde. Un cycliste de 55 ans, habitant d'Eysines et agent d'entretien, se rendait sur son lieu de travail à vélo.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "vx9xmhcca",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
