        "id": "7whackky9g",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Au niveau du rond-point Madeleine Pelletier, au croisement de la rue Caroline Aigle et de l'avenue de Magudas, il aurait été percuté par un poids lourd porte-char. Selon les éléments de l'enquête, la victime aurait été traînée sur plus d'un kilomètre.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "yrcdc2gznw",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
