          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Son entrée en vigueur date de juillet 2025",
              "decorations": [
                {
                  "type": "LINK",
                  "linkData": {
                    "link": {
                      "url": "https://www.securite-routiere.gouv.fr/actualites-page-1-189/entree-en-vigueur-de-la-loi-creant-lhomicide-routier-et-visant-lutter-contre",
