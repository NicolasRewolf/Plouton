      {
        "type": "BULLETED_LIST",
        "id": "hdwym3zqzq",
        "nodes": [
          {
            "type": "LIST_ITEM",
            "id": "r6xdh68mpq",
            "nodes": [
              {
                "type": "PARAGRAPH",
                "id": "2czuw4hkcq",
                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "Contestation formelle du délit de fuite.",
                      "decorations": [
                        {
                          "type": "BOLD"
                        }
                      ]
                    }
                  },
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": " Notre client indique ne pas avoir vu le cycliste au moment de tourner. Le cycliste se serait trouvé dans un angle mort du poids lourd. Cette version, bien que difficile à entendre pour les proches de la victime, soulève une problématique technique réelle : la visibilité limitée depuis la cabine d'un véhicule poids lourd, particulièrement lors d'un changement de direction.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
          {
            "type": "LIST_ITEM",
            "id": "u6x0dqr3hg",
            "nodes": [
              {
                "type": "PARAGRAPH",
                "id": "cfakc3rkya",
                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "Absence de risque de fuite.",
                      "decorations": [
                        {
                          "type": "BOLD"
                        }
                      ]
                    }
                  },
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": " Notre client a reconnu en garde à vue être potentiellement à l'origine du décès. Le Cabinet a mis en avant qu'il ne présentait pas de risque de soustraction à la justice.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
          {
            "type": "LIST_ITEM",
            "id": "tmtmjgfoq",
            "nodes": [
              {
                "type": "PARAGRAPH",
                "id": "dwktatdfq",
                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "Volonté de coopération.",
                      "decorations": [
                        {
                          "type": "BOLD"
                        }
                      ]
                    }
                  },
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": " Notre client s'est déclaré prêt à coopérer pleinement avec l'instruction et à se présenter à tous les actes de la procédure.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
