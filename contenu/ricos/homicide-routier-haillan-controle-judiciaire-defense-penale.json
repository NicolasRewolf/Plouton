        "id": "zsrcnlsngw",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "À 5 h du matin, des conducteurs découvrent le corps sans vie du cycliste sur la chaussée.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "8vscmmwwng",
        "nodes": [
          {
