            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ". Cette infraction vise à punir plus sévèrement l'homicide involontaire lié à des circonstances d'une conduite délibérément à risque. La peine encourue est de ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "sept ans d'emprisonnement et 100 000 euros d'amende",
