          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Introduite dans le Code de procédure pénale en 2014 et diffusée plus largement depuis 2017 grâce aux actions des CRIAVS, la justice restaurative a gagné en visibilité auprès du grand public avec la sortie du film ",
              "decorations": []
