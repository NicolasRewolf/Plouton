                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " de Jeanne Herry. Cette approche novatrice propose aux victimes et aux auteurs de se rencontrer, dans un cadre sécurisé, pour ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "donner un espace à la parole et à l’écoute mutuelle",
              "decorations": [
                {
                  "type": "BOLD",
                  "fontWeightValue": 700
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ", là où la justice pénale classique reste souvent cantonnée à une logique d’opposition.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {
          "textStyle": {
            "textAlignment": "AUTO"
          }
        }
      },
