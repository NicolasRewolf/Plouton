      },
      {
        "type": "HEADING",
        "id": "s11miaggya",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "L'intervention du cabinet pour la CAF",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2.0
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "b5o2ydhzq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Me Julien Plouton, conseil de la Caisse d'allocations familiales, a dénoncé à l'audience la « mauvaise foi de Stéphane Chapin pour échapper à ses responsabilités ». La CAF, partie civile, sollicitait la reconnaissance du préjudice résultant des 2 594 euros de prestations indûment perçues.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "q6szzk4oia",
        "nodes": [
          {
            "type": "TEXT",
