        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "À ces faits s'ajoute une fraude aux prestations sociales : le couple aurait perçu ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "2 594 euros",
              "decorations": [
                {
                  "type": "BOLD"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " d'aides au logement de manière indue, alors qu'il était hébergé à titre gratuit.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "edjtpyxoq",
        "nodes": [
          {
