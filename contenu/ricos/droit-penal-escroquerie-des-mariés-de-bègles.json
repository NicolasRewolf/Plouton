            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "ytvmzuw3ca",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "En parallèle de ce contentieux civil, une procédure pénale s'est ouverte. Les deux hommes ont comparu devant la 5e chambre du tribunal correctionnel de Bordeaux le 29 septembre 2006 pour répondre de plusieurs infractions commises en 2004, à l'époque même de leur mariage.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
