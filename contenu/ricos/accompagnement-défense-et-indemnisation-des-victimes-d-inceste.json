                "id": "qvjq0vcia",
                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "Le financement par la Sécurité sociale d'un parcours de soins spécialisés en psychotraumatisme pour accompagner les victimes.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          }
        ],
        "bulletedListData": {
          "indentation": 0.0
        }
      },
      {
        "type": "PARAGRAPH",
