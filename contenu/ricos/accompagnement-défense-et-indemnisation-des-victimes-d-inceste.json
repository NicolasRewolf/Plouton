                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "Rendre imprescriptibles les viols et agressions sexuelles sur des enfants. Actuellement, cette prescription est de trente ans après la majorité de la victime.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
          {
            "type": "LIST_ITEM",
            "id": "fis9b0qta",
            "nodes": [
              {
                "type": "PARAGRAPH",
                "id": "twrlf6qyw",
                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "La mise en place d'une ordonnance de sûreté de l'enfant, calquée sur l'ordonnance de protection pour les femmes victimes de violences. Cette ordonnance permettrait aux Juges aux Affaires Familiales (JAF) de statuer en urgence en cas « d'inceste vraisemblable ».",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
          {
            "type": "LIST_ITEM",
            "id": "ojfbqdn0a",
            "nodes": [
              {
