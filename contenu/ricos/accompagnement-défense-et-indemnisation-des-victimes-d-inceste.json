      {
        "type": "PARAGRAPH",
        "id": "sj5da00k3g",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Sans revenir sur les polémiques liées à sa composition et l'éviction puis la nomination d'un nouveau président, ses pouvoirs ont été récemment étendus à la lutte contre la prostitution des mineurs, à la lutte contre la cyberpédocriminalité et à la protection des mineurs handicapés – davantage soumis au risque d'agressions sexuelles en raison de leur handicap.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "x4sptrsbya",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
