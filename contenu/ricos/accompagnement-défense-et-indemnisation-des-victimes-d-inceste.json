          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Ses principales préconisations sont :",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "e9sz7fomdq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
