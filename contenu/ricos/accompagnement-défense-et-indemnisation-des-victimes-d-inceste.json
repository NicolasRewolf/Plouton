          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Après 2 ans et demi de travaux et plus de 27 000 témoignages recueillis, la Commission indépendante sur l'inceste et les violences sexuelles faites aux enfants (CIIVISE) remet fin novembre 2023 un rapport comprenant 82 préconisations.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "c80okrihha",
