          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Le dénouement : la relaxe prononcée",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "mncyyqrb8w",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Le Tribunal Correctionnel a validé notre argumentation point par point. Il n'a pu que constater l'extinction de l'action publique et, par conséquent, l'abandon des poursuites.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "4f5btfapkw",
        "nodes": [
          {
