        "id": "iwda5l0dya",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Durant toute la procédure, il a maintenu avoir agi en désespoir de cause, se sentant acculé et délaissé par sa hiérarchie. La banque, de son côté, se prévalait d'un préjudice de près de ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "2 millions d'euros",
              "decorations": [
                {
                  "type": "BOLD"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ", correspondant aux fonds consentis sans garantie et jamais recouvrés.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "yxbbbgdbqa",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
