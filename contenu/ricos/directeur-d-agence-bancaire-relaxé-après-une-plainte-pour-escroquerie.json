        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Après avoir été informé qu'un audit complémentaire serait mené, les supérieurs de Monsieur H. lui ont demandé de régulariser l'ensemble de ses dossiers. Se sentant abandonné par sa hiérarchie, Monsieur H. n'a eu d'autre choix que de ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "falsifier des documents",
              "decorations": [
                {
                  "type": "BOLD"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " pour donner un semblant de régularité aux dossiers.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "agmve0heaq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
