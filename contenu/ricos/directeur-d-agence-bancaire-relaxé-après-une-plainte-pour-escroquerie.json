      },
      {
        "type": "PARAGRAPH",
        "id": "7qdch8l3kg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Suite à une plainte de la banque en 2009, puis une plainte avec constitution de partie civile en 2012, ce n'est finalement qu'en 2022 que Monsieur H. a été renvoyé devant le Tribunal Correctionnel, uniquement pour le chef de ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "faux",
              "decorations": [
                {
                  "type": "BOLD"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ".",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
