            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "09zn57wqxq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Loin d'être un faussaire hors pair, ses agissements ont été rapidement découverts. Interrogé, il a immédiatement reconnu être l'auteur des faux, ce qu'il confirmera plus tard devant les enquêteurs.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "msszfmrqvg",
        "nodes": [
          {
            "type": "TEXT",
