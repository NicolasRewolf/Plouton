            "nodes": [],
            "textData": {
              "text": "Cette disparition brutale et tragique s'abattra comme une malédiction sur ce groupe d'amis. Et marquera la fin de leur innocence.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
