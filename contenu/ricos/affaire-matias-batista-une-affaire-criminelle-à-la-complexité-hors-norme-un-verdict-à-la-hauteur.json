        "id": "2apiozsvw",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Été 2015 : le suicide de Danaël, point de départ du drame",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "ijvl0x2lbq",
        "nodes": [
          {
            "type": "TEXT",
