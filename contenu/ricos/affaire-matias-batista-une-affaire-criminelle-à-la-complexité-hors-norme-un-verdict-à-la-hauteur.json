          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "2016-2018 : les révélations d'une mère en deuil pathologique",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "uepbvyd3zw",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
