              "text": " ",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "HEADING",
        "id": "ijwywvjhba",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Le témoignage bouleversant d'Isabelle Munoz Alvarez",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 3
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "xc7u2nk1ww",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "mlrt4y2jqa",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Le point d'orgue de ce procès fut le témoignage d'Isabelle Munoz Alvarez, maman de Danaël. À la barre, cette femme de 61 ans, brisée, a soutenu l'accusé avec une émotion palpable : ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "\"Je suis une victime, Danaël est une victime, et Samuel est une victime collatérale. À qui la faute ? Ça vient de qui tout ça ?\"",
              "decorations": [
                {
                  "type": "ITALIC"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ". Puis, dans un geste qui a stupéfié la cour, elle est venue s'asseoir sur le banc de la défense, aux côtés de la famille de Samuel, comme pour matérialiser cette solidarité des écorchés.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
