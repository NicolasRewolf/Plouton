        "id": "lc2n72214",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Face à l’accumulation de preuves – écoutes téléphoniques, sonorisations des véhicules et géolocalisation des lignes Telegram – le cabinet Julien Plouton a vigoureusement contesté la construction intellectuelle établie par les enquêteurs et le magistrat instructeur.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {
          "textStyle": {
            "textAlignment": "AUTO"
          }
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "d7lte2285",
        "nodes": [],
