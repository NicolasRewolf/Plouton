                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "Bien que quelques écoutes aient partiellement reconnu le rôle de gestionnaire, une analyse exhaustive a révélé l’existence d’un fonctionnement horizontal du réseau, où les échanges de conseils et directives entre pairs étaient la norme.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
          {
            "type": "LIST_ITEM",
            "id": "elis82224",
