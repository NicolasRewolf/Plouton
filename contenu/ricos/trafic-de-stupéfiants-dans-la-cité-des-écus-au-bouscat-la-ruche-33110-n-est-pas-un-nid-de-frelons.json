      {
        "type": "HEADING",
        "id": "145vq2534",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Une Défense Fondée sur l’Équité et la Réalité des Faits",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 3.0,
          "textStyle": {
            "textAlignment": "AUTO"
          }
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "kr65d2536",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Issu d’un milieu social difficile, marqué par des expériences traumatisantes et une précarité avérée – comme en témoigne son expulsion par voie d’huissier – notre client se trouvait dans une situation d’urgence qui, selon Laurent Gaude, illustre « la gifle des pauvres ». Le cabinet Plouton a ainsi souligné que, contrairement aux accusations, il n’existait aucune preuve d’un rôle prépondérant ou d’un climat d’intimidation au sein du réseau.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {
          "textStyle": {
            "textAlignment": "AUTO"
          }
        }
      },
