                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "Examen de la Ligne Telegram",
                      "decorations": [
                        {
                          "type": "BOLD",
                          "fontWeightValue": 700.0
                        }
                      ]
                    }
                  },
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": " :",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              },
              {
                "type": "PARAGRAPH",
                "id": "uc0tw2229",
                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "L’analyse des messages et des « Fadettes » a mis en évidence que la gestion de la ligne destinée à la vente de cocaïne impliquait plusieurs individus, remettant en question l’attribution exclusive des faits à notre client.",
                      "decorations": []
                    }
                  },
                  {
