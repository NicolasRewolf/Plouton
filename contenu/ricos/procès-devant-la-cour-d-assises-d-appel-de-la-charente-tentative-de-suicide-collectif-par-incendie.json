        "id": "cjxhmqvjhg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Mme S. et Mme M. avaient à cœur de faire entendre leur vision des faits. L'",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "objectif pour la Défense",
              "decorations": [
                {
                  "type": "BOLD"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " était d'arriver à faire comprendre à la Cour que la gravité de leur acte ne devait pas avoir pour conséquence la négation de leur humanité et des sentiments qui en découlent.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "pspl9rzv3w",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
