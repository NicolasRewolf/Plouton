          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "La Cour d'assises, après de longs délibérés, a décidé de condamner Mme S. à une peine de ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "20 ans de",
              "decorations": [
                {
                  "type": "BOLD"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "réclusion criminelle",
              "decorations": [
                {
                  "type": "BOLD"
                },
                {
                  "type": "LINK",
                  "linkData": {
                    "link": {
                      "url": "https://www.jplouton-avocat.fr/defense-penale/droit-penal",
