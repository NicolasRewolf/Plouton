          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Les plaidoiries ont permis d'exprimer la souffrance qu'est la leur aujourd'hui de ne plus avoir de contact avec cette petite fille, et de conduire la Cour et les jurés à parcourir ce chemin royal qui conduit de l'acte à l'Homme.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
