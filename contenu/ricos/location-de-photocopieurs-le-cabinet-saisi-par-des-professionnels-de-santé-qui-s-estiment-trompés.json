        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Le commercial laissait croire aux entreprises qu'elles deviendraient une vitrine commerciale pour le matériel et les services proposés par la société venderesse, soit une véritable opportunité pour elles d'acquérir une installation de qualité à moindre coût.",
              "decorations": []
            }
