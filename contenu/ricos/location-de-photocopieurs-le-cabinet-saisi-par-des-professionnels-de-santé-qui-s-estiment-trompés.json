        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Il leur était proposé un « partenariat commercial » leur permettant d'acquérir, pour la somme de 5 euros par mois, un photocopieur de dernière génération en échange de leur concours quant à la promotion de ces produits.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
