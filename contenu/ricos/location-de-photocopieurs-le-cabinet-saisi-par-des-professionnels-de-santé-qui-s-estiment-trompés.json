        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Le principe était simple en apparence : en contrepartie de la quasi-gratuité de leur matériel, les cabinets de diététiques devaient répondre aux appels des futurs clients et leur exprimer leur avis sur les photocopieurs installés et les prestations de maintenance de la société.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
