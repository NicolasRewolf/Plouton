                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " qui sera désormais ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "en charge des investigations",
              "decorations": [
                {
                  "type": "BOLD",
                  "fontWeightValue": 700
                }
              ]
            }
          },
          {
            "type": "TEXT",
