                        "type": "TEXT",
                        "id": "",
                        "nodes": [],
                        "textData": {
                          "text": "Ressources Juridiques - Qu’est-ce que le statut de témoin assisté ?",
                          "decorations": [
                            {
                              "type": "BOLD",
                              "fontWeightValue": 700
