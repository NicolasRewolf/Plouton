          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Selon le Parquet de Bordeaux, les faits s’inscriraient dans un ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "contexte de narco trafic et de tentative de prise de contrôle d’un point de deal ",
