        "id": "plqkrioxaw",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Le juge d'instruction devra donc reconstituer précisément la chronologie de la soirée et déterminer les responsabilités de chacun.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
