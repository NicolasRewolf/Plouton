            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "L'essentiel de l'affaire",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2.0
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "psuqzejn7q",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
