            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "chauffeur",
              "decorations": [
                {
                  "type": "BOLD"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " qu'il a ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
