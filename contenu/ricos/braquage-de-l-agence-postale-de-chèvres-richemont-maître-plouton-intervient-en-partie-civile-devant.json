        "id": "b5xck2kjoa",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Et de réclamer finalement la même peine pour les deux accusés : de 13 à 15 ans de réclusion criminelle assortie d'une période de sûreté de la moitié et d'un suivi socio-judiciaire de dix ans.",
              "decorations": []
            }
          }
