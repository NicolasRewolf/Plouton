          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ", ainsi qu'aux trois magistrats, à s'enfermer dans la salle des délibérations. Pour laisser parler leur intime conviction et forger leur délibéré.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
