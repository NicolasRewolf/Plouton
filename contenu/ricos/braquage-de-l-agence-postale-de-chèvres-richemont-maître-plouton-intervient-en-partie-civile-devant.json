        "id": "4txscdl3za",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "« Lors des faits, je ne me suis pas rendu compte du mal que je faisais aux otages. Je l'ai appris pendant cette audience. Je leur dis tous mes regrets. »",
              "decorations": [
                {
                  "type": "ITALIC"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " Fabrice G, hier soir, a choisi de s'adresser aux ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
