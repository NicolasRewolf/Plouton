              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "« Je me suis expliqué. Je ne peux plus rien faire de plus si ce n'est faire confiance à la justice. »",
