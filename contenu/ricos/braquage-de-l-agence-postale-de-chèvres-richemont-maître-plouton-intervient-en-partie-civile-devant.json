              "text": " ",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "HEADING",
        "id": "sx4p0lu2xg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "La plaidoirie de Maître Plouton : trente minutes pour dire la souffrance",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2.0
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "v2tggvhvpa",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Face à cette nébuleuse, Pierre-Yves Couilleau plantera ses banderilles les unes après les autres dans la vérité du dossier qui, selon lui, n'amène qu'à un seul et unique comparse : Mickaël N.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "5wog45odna",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "aztq7e8vw",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Me Julien Plouton, avocat de la Poste et de ses huit employés séquestrés",
              "decorations": [
                {
                  "type": "BOLD"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ", se livra, lors de la première plaidoirie de cette journée, à un exercice astucieux : trente minutes de plaidoiries pour dire la souffrance et la crainte de ses clients. Le temps de leur séquestration, à quelques minutes près. ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "« J'ai été trop long ? C'est ce qu'ils ont vécu, alors que cela pouvait déraper à tout moment. »",
              "decorations": [
                {
                  "type": "ITALIC"
                }
              ]
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "0uhtgtozg",
        "nodes": [
          {
            "type": "TEXT",
