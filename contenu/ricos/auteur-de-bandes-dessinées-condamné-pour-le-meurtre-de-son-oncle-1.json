        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Les témoins entendus en procédure soulignaient que, pour Guy L., la relation la plus importante de sa vie était celle qu'il nourrissait avec son neveu. Il était particulièrement ",
              "decorations": []
            }
          },
