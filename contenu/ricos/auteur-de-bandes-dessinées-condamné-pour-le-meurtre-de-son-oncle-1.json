          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ", qui jouait auprès de lui le rôle d'un second père, le père de Fabien M. ayant été écarté depuis de nombreuses années par la mère.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
