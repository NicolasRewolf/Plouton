        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Fabien M., âgé de plus de 40 ans au moment des faits, vivait en effet toujours chez sa mère dont il était partiellement dépendant. Il entretenait par ailleurs des ",
              "decorations": []
            }
          },
