                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " et l'accompagnait régulièrement sur des salons et autres expositions de bandes dessinées pour l'aider à promouvoir ses albums.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
