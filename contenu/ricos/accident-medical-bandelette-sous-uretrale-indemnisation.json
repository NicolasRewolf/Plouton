            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "L'expertise médicale a mis en lumière plusieurs points cruciaux :",
              "decorations": [
                {
                  "type": "COLOR",
                  "colorData": {
                    "background": "transparent",
                    "foreground": "#17475E"
                  }
                }
