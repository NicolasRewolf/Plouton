          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Cette affaire met en lumière deux types de fautes médicales :",
              "decorations": [
                {
                  "type": "COLOR",
                  "colorData": {
                    "background": "transparent",
                    "foreground": "#17475E"
                  }
                }
