                  "type": "UNDERLINE"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ", illustre à quel point ce relevé initial pèse sur l'issue d'un dossier.",
              "decorations": []
