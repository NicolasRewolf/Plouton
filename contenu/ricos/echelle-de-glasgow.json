      {
        "type": "PARAGRAPH",
        "id": "63fl02233",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Ce score, consigné dès les premiers secours, ne reste pas un simple chiffre médical : il devient une donnée juridique. Il sert de point de départ aux experts comme aux juridictions pour apprécier la gravité de l'atteinte et l'ampleur du préjudice. L'affaire jugée par le ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Tribunal judiciaire de Pau, où un « score de Glasgow à 4 » a fondé la reconnaissance d'un préjudice d'angoisse de mort imminente",
              "decorations": [
                {
                  "type": "LINK",
                  "linkData": {
                    "link": {
                      "url": "https://www.jplouton-avocat.fr/post/accident-mortel-angoisse-mort-imminente-tj-pau",
                      "target": "BLANK"
                    }
