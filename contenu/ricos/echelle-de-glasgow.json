          "html": "<!DOCTYPE html>\n<html lang=\"fr\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Calculateur de l'échelle de Glasgow</title>\n<style>\n  :root{\n    --petrole:#17475E; --petrole-2:#3F6E84; --bleu-clair:#83ACF8;\n    --corail:#FE4B42; --taupe:#C1B1A2; --white:#FFFFFF;\n    --g2:#F0F0F0; --g3:#D9D9D9; --ink:#17475E; --muted:#6E7C84;\n    --petrole-soft:#EAF0F3;\n    --shadow:0 1px 2px rgba(23,71,94,.05),0 10px 30px rgba(23,71,94,.08);\n    --font:'Source Sans 3','Google Sans',-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;\n  }\n  *{box-sizing:border-box;margin:0;padding:0}\n  html,body{background:transparent}\n  body{font-family:var(--font);color:var(--ink);line-height:1.5;-webkit-font-smoothing:antialiased;padding:8px}\n  .wrap{max-width:100%;margin:0 auto;background:var(--white);border:1px solid var(--g2);border-radius:16px;overflow:hidden;box-shadow:var(--shadow)}\n  .head{padding:22px 26px 20px;background:linear-gradient(180deg,var(--petrole),var(--petrole-2));color:#fff;position:relative}\n  .head::after{content:'';position:absolute;left:0;right:0;bottom:0;height:3px;background:var(--corail)}\n  .head h1{font-weight:700;font-size:1.35rem;line-height:1.15}\n  .progress{display:flex;gap:6px;margin-top:14px}\n  .progress span{flex:1;height:4px;border-radius:3px;background:rgba(255,255,255,.25);transition:background .2s}\n  .progress span.done{background:var(--bleu-clair)}\n  .progress span.active{background:#fff}\n  .stage{padding:22px 26px}\n  .step-label{font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;color:var(--petrole-2);font-weight:700;margin-bottom:4px}\n  .step-q{font-size:1.05rem;font-weight:700;margin-bottom:16px}\n  .options{display:flex;flex-direction:column;gap:8px}\n  .opt{display:flex;align-items:center;gap:13px;padding:11px 14px;border:1.5px solid var(--g2);border-radius:10px;background:var(--white);cursor:pointer;transition:border-color .12s,background .12s,transform .08s;text-align:left;width:100%;font-family:inherit;color:inherit}\n  .opt:hover{border-color:var(--petrole);background:var(--petrole-soft)}\n  .opt:active{transform:scale(.99)}\n  .opt-text{flex:1;font-size:.9rem;font-weight:600}\n  .opt-text small{display:block;color:var(--muted);font-size:.78rem;font-weight:400;margin-top:1px}\n  .chip{font-weight:700;font-size:.82rem;min-width:30px;text-align:center;padding:3px 9px;border-radius:6px;background:var(--petrole-soft);color:var(--petrole)}\n  .opt.nt .chip{background:var(--g2);color:var(--muted)}\n  .nav{display:flex;align-items:center;gap:10px;margin-top:18px}\n  .back{background:none;border:none;color:var(--muted);font-family:inherit;font-size:.85rem;font-weight:600;cursor:pointer;padding:6px 4px}\n  .back:hover{color:var(--petrole)}\n  .running{margin-left:auto;font-size:.8rem;color:var(--muted);font-weight:600}\n  .running b{color:var(--petrole)}\n  /* Result */\n  .result{padding:26px}\n  .res-card{background:var(--petrole);color:#fff;border-radius:13px;padding:22px 24px;display:flex;align-items:center;gap:20px;flex-wrap:wrap}\n  .total{display:flex;align-items:baseline;gap:4px}\n  .total .n{font-size:3rem;font-weight:700;line-height:.9}\n  .total .d{font-size:1rem;color:rgba(255,255,255,.6);font-weight:600}\n  .breakdown{font-size:.95rem;font-weight:700}\n  .breakdown small{display:block;font-weight:500;color:rgba(255,255,255,.6);font-size:.7rem;letter-spacing:.04em;margin-top:3px;text-transform:uppercase}\n  .sev{margin-left:auto;text-align:right}\n  .sev-badge{display:inline-block;padding:5px 13px;border-radius:30px;font-size:.8rem;font-weight:700}\n  .sev-badge.severe{background:var(--corail)}\n  .sev-badge.moderate{background:var(--taupe);color:#3a2f26}\n  .sev-badge.mild{background:var(--bleu-clair);color:#10324a}\n  .sev-badge.nt{background:rgba(255,255,255,.16)}\n  .sev small{display:block;color:rgba(255,255,255,.65);font-size:.74rem;margin-top:6px;max-width:24ch}\n  .restart{margin-top:16px;width:100%;background:var(--petrole-soft);border:none;color:var(--petrole);font-family:inherit;font-size:.85rem;font-weight:700;padding:11px;border-radius:9px;cursor:pointer;transition:background .12s}\n  .restart:hover{background:#dde7ec}\n  .note{padding:0 26px 22px;font-size:.76rem;color:var(--muted);line-height:1.55}\n  .note strong{color:var(--petrole-2)}\n  .hidden{display:none}\n  @media(max-width:480px){\n    .head{padding:20px}.stage{padding:20px}.result{padding:20px}\n    .sev{margin-left:0;text-align:left;width:100%}.total .n{font-size:2.6rem}\n  }\n</style>\n</head>\n<body>\n<div class=\"wrap\">\n  <header class=\"head\">\n    <h1>Calculateur de l'échelle de Glasgow</h1>\n    <div class=\"progress\" id=\"progress\"><span></span><span></span><span></span></div>\n  </header>\n\n  <div class=\"stage\" id=\"stage\"></div>\n\n  <div class=\"result hidden\" id=\"result\">\n    <div class=\"res-card\">\n      <div class=\"total\"><span class=\"n\" id=\"totalN\">—</span><span class=\"d\" id=\"totalD\">/15</span></div>\n      <div class=\"breakdown\" id=\"breakdown\">E– V– M–<small>Détail par composante</small></div>\n      <div class=\"sev\">\n        <span class=\"sev-badge nt\" id=\"sevBadge\">—</span>\n        <small id=\"sevText\"></small>\n      </div>\n    </div>\n    <button class=\"restart\" id=\"restart\">Recommencer l'évaluation</button>\n  </div>\n\n  <p class=\"note\">\n    <strong>À titre informatif.</strong> Cet outil reproduit l'échelle de Glasgow (révision 2014) à des fins de compréhension et ne remplace pas un avis médical. Si une composante est « non testable » (NT), le total ne s'additionne pas&nbsp;: seuls les sous-scores font foi.\n  </p>\n</div>\n\n<script>\nconst steps = [\n  { key:\"E\", q:\"Ouverture des yeux\", opts:[\n    {s:4,t:\"Spontanée\",d:\"Yeux ouverts avant tout stimulus\"},\n    {s:3,t:\"À la parole\",d:\"Ouvre les yeux à la demande verbale\"},\n    {s:2,t:\"À la pression\",d:\"Ouvre les yeux à un stimulus de pression\"},\n    {s:1,t:\"Aucune\",d:\"Pas d'ouverture, sans facteur interférent\"},\n    {s:\"NT\",t:\"Non testable\",d:\"Œdème, traumatisme facial…\"}\n  ]},\n  { key:\"V\", q:\"Réponse verbale\", opts:[\n    {s:5,t:\"Orientée\",d:\"Nom, lieu et date corrects\"},\n    {s:4,t:\"Confuse\",d:\"Communique mais désorientée\"},\n    {s:3,t:\"Mots inappropriés\",d:\"Mots isolés intelligibles\"},\n    {s:2,t:\"Sons\",d:\"Gémissements, grognements\"},\n    {s:1,t:\"Aucune\",d:\"Pas de réponse audible, sans facteur interférent\"},\n    {s:\"NT\",t:\"Non testable\",d:\"Intubation, trachéotomie…\"}\n  ]},\n  { key:\"M\", q:\"Réponse motrice\", opts:[\n    {s:6,t:\"Obéit aux ordres\",d:\"Exécute une consigne en deux temps\"},\n    {s:5,t:\"Localise\",d:\"Porte la main au-dessus de la clavicule\"},\n    {s:4,t:\"Flexion normale\",d:\"Retrait rapide du bras\"},\n    {s:3,t:\"Flexion anormale\",d:\"Décortication\"},\n    {s:2,t:\"Extension\",d:\"Décérébration\"},\n    {s:1,t:\"Aucune\",d:\"Aucun mouvement, sans facteur interférent\"},\n    {s:\"NT\",t:\"Non testable\",d:\"Paralysie, curarisation…\"}\n  ]}\n];\nconst sel = {E:null,V:null,M:null};\nlet cur = 0;\nconst stage=document.getElementById('stage');\nconst result=document.getElementById('result');\nconst prog=document.getElementById('progress').children;\n\nfunction runningTotal(){\n  let parts=[];\n  ['E','V','M'].forEach(k=>{ if(sel[k]!==null) parts.push(k+sel[k]); });\n  return parts.join(' ');\n}\nfunction renderStep(){\n  result.classList.add('hidden');\n  stage.classList.remove('hidden');\n  const st=steps[cur];\n  for(let i=0;i<3;i++){\n    prog[i].className = i<cur?'done':(i===cur?'active':'');\n  }\n  let html=`<div class=\"step-label\">Étape ${cur+1} sur 3 · « ${st.key} »</div>\n    <div class=\"step-q\">${st.q}</div><div class=\"options\">`;\n  st.opts.forEach((o,idx)=>{\n    html+=`<button class=\"opt${o.s==='NT'?' nt':''}\" data-i=\"${idx}\">\n      <span class=\"opt-text\">${o.t}<small>${o.d}</small></span>\n      <span class=\"chip\">${o.s}</span></button>`;\n  });\n  html+=`</div><div class=\"nav\">`;\n  if(cur>0) html+=`<button class=\"back\" id=\"back\">← Retour</button>`;\n  const rt=runningTotal();\n  if(rt) html+=`<span class=\"running\">En cours&nbsp;: <b>${rt}</b></span>`;\n  html+=`</div>`;\n  stage.innerHTML=html;\n  stage.querySelectorAll('.opt').forEach(b=>{\n    b.addEventListener('click',()=>{\n      sel[st.key]=st.opts[+b.dataset.i].s;\n      if(cur<2){cur++;renderStep();} else {renderResult();}\n    });\n  });\n  const back=document.getElementById('back');\n  if(back) back.addEventListener('click',()=>{cur--;renderStep();});\n}\nfunction renderResult(){\n  stage.classList.add('hidden');\n  result.classList.remove('hidden');\n  for(let i=0;i<3;i++) prog[i].className='done';\n  document.getElementById('breakdown').innerHTML=\n    `E${sel.E} V${sel.V} M${sel.M}<small>Détail par composante</small>`;\n  const totalN=document.getElementById('totalN');\n  const totalD=document.getElementById('totalD');\n  const badge=document.getElementById('sevBadge');\n  const sevText=document.getElementById('sevText');\n  if([sel.E,sel.V,sel.M].includes('NT')){\n    totalN.textContent='NT'; totalD.style.display='none';\n    badge.className='sev-badge nt'; badge.textContent='Non additionnable';\n    sevText.textContent='Une composante non testable empêche le calcul du total.';\n    return;\n  }\n  const sum=sel.E+sel.V+sel.M;\n  totalN.textContent=sum; totalD.style.display='';\n  let cls,txt,desc;\n  if(sum<=8){cls='severe';txt='Atteinte sévère';desc='GCS 3–8';}\n  else if(sum<=12){cls='moderate';txt='Atteinte modérée';desc='GCS 9–12';}\n  else{cls='mild';txt='Atteinte légère';desc='GCS 13–15';}\n  badge.className='sev-badge '+cls; badge.textContent=txt; sevText.textContent=desc;\n}\ndocument.getElementById('restart').addEventListener('click',()=>{\n  sel.E=sel.V=sel.M=null; cur=0; renderStep();\n});\nrenderStep();\n</script>\n</body>\n</html>",
          "source": "HTML"
        }
