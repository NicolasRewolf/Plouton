        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "La Cour d'appel a fait droit à notre demande visant à faire reconnaître une faute de la banque dans le déblocage des fonds. Elle a jugé que Monsieur C et Madame P n'auront pas à restituer les ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "26 500 €",
              "decorations": [
