            "id": "",
            "nodes": [],
            "textData": {
              "text": "La Cour a en outre jugé que la signature de l'attestation de fin de travaux par Monsieur C et Madame P ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "ne caractérisait pas leur volonté de régulariser",
