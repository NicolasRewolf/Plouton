              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " les vices du contrat. Nos clients n'avaient pas connaissance des insuffisances du bon de commande et ne pouvaient donc entendre y renoncer en signant cette attestation.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
