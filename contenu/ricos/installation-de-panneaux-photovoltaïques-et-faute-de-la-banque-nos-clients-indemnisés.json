        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "La Cour a précisé que la banque a commis une faute en débloquant les fonds sur la seule base d'une attestation de fin de travaux, alors qu'un examen rapide du bon de commande lui aurait permis de constater que le contrat principal ne respectait pas les dispositions du Code de la consommation et que le raccordement prévu n'avait pas été effectué.",
              "decorations": [
                {
                  "type": "BOLD"
                }
              ]
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "poqucw0ocg",
        "nodes": [
