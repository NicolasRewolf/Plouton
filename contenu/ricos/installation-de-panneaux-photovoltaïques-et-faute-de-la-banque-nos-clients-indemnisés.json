        "id": "ep7at5vka",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "La faute de la banque : 26 500 € que nos clients n'ont pas à restituer",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2.0
        }
