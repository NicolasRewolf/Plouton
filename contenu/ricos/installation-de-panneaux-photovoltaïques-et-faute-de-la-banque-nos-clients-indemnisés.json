        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Dès lors, la banque ne pouvait ignorer que le contrat de crédit affecté encourait lui aussi la nullité, les lacunes du bon de commande et l'absence de raccordement étant apparents.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
