        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Les agresseurs prenaient alors immédiatement la fuite en direction de l'Espagne pour une cavale de plusieurs mois. Ils en justifiaient l'origine par la peur des représailles, mais cette fuite leur permettait surtout de préparer leur ligne de défense.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
