              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ", tandis que ses deux fils étaient poursuivis pour violences volontaires en réunion avec arme.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
