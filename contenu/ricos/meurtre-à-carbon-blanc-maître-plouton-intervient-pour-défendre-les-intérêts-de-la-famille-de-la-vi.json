            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "mis en accusation devant la Cour d'Assises de la GIRONDE du chef d'homicide volontaire",
              "decorations": [
                {
                  "type": "LINK",
                  "linkData": {
                    "link": {
