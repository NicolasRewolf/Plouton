          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "La stratégie de défense : démontrer le défaut de formation de l'employeur",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2
        }
      },
