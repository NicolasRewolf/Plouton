            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "HEADING",
        "id": "fmhjtn8zq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Les faits : d'un poste de rippeur à un reclassement non accompagné",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "oarnp03kkg",
        "nodes": [
          {
            "type": "TEXT",
