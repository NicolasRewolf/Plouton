        "id": "99xrfpnqzq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Selon l'article 132-2 du Code pénal, ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "« il y a concours d'infractions lorsqu'une infraction est commise par une personne avant que celle-ci ait été définitivement condamnée pour une autre infraction ».",
