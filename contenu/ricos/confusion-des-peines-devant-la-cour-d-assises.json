        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Dans ce cas, l'article 132-4 du Code pénal dispose que ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
