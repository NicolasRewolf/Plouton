        "id": "60e29hlfhw",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Il s'agissait d'obtenir la peine la plus adaptée à sa personnalité carencée, qui constituait à mon sens la principale circonstance atténuante.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
