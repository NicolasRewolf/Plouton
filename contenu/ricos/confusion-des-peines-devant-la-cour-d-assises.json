          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "différence de traitement arbitraire",
              "decorations": [
                {
                  "type": "BOLD"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " dictée par le seul choix du Parquet (poursuite unique ou plurielles), le législateur a prévu le ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "mécanisme de la confusion des peines, outil de bonne administration de la justice et garantissant le principe constitutionnel de personnalisation des peines.",
              "decorations": [
                {
                  "type": "BOLD"
                }
              ]
            }
          }
        ],
        "paragraphData": {}
