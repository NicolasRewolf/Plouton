        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Ces infractions en concours peuvent faire l'objet d'une poursuite unique ou d'une pluralité de poursuites.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
