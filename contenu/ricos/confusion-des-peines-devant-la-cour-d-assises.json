        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Dans cette optique, j'entendais également solliciter dans le cadre des débats la confusion de la peine que ne manquerait pas de prononcer la Cour d'assises avec celle déjà prononcée par le Tribunal correctionnel de Libourne.",
              "decorations": [
                {
                  "type": "BOLD"
                }
              ]
            }
