      {
        "type": "PARAGRAPH",
        "id": "y41ufwlmeq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "S'agissant des conditions de recevabilité, ",
