        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Une stratégie de défense centrée sur la personnalité et la confusion des peines",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2.0
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "zpgzhn43a",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Les faits n'étant pas contestés, j'entendais plaider sur la personnalité de mon client, jeune homme à peine sorti de l'adolescence et dont l'instabilité trouvait sa cause principale dans une rupture familiale précoce.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "fne7tllfng",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
