        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Ce mécanisme de confusion a pour effet de ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "faire absorber une peine (la plus faible) prononcée par une juridiction par une autre peine (la plus sévère) de même nature prononcée par une autre juridiction.",
