        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "En cas de diversité de compétence juridictionnelle ou de découverte de différentes infractions dans des temps différents, les faits peuvent faire l'objet de ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "poursuites distinctes comme en l'espèce.",
