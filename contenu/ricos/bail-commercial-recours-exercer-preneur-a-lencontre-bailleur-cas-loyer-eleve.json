                "type": "PARAGRAPH",
                "id": "a862n603",
                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "En 2025, notez que dans certaines communes, les nouveaux Tribunaux des Activités Économiques (TAE) sont compétents pour les litiges nés d'une procédure collective.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
