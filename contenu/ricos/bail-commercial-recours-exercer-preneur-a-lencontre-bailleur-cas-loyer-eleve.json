                "type": "PARAGRAPH",
                "id": "lrrvc609",
                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "L'action en fixation du loyer doit être introduite dans un délai de 2 ans à compter de la demande de révision, sous peine de forclusion.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          }
        ],
