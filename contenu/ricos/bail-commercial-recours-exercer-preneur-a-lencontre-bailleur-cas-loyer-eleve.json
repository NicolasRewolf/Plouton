                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "Le juge fixe alors directement le loyer commercial ou ordonne une expertise pour déterminer la valeur locative précise.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
          {
            "type": "LIST_ITEM",
            "id": "2magm608",
            "nodes": [
