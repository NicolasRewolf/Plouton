                          "linkData": {
                            "link": {
                              "url": "https://www.justice.fr/recherche/annuaires",
                              "target": "BLANK"
                            }
                          }
                        },
                        {
                          "type": "UNDERLINE"
                        }
                      ]
                    }
                  },
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": " (qui a remplacé le TGI depuis 2020) du lieu de l'immeuble par voie d'assignation.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
