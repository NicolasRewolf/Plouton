          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ". Cinq membres d'une même famille étaient poursuivis pour l'exploitation de travailleurs saisonniers marocains. Maître Julien Plouton défendait le gérant de l'entreprise de prestations viticoles. Le délibéré a été rendu le 25 juillet 2024.",
              "decorations": []
            }
