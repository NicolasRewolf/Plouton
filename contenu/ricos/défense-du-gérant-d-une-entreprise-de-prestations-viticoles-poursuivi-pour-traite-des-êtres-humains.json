        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Défendre un chef d'entreprise face à des accusations graves",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "ndkeikdz4q",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Ce procès illustre les défis juridiques posés par la ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "défense des chefs d'entreprise en cas de poursuites pénales",
              "decorations": [
                {
                  "type": "BOLD"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " liées à leur activité et à la gestion de leurs salariés. Il met en lumière le travail d'avocats comme Maître Plouton, engagés à garantir une ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "défense rigoureuse et efficace face à des qualifications pénales lourdes",
              "decorations": [
                {
                  "type": "BOLD"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " comme la traite d'êtres humains.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
