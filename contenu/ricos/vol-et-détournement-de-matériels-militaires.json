            "textData": {
              "text": "Tribunal Correctionnel de BORDEAUX, Chambre spécialisée en Section militaire, 11 octobre 2019",
              "decorations": [
                {
                  "type": "ITALIC"
                }
              ]
            }
          }
        ],
        "paragraphData": {}
