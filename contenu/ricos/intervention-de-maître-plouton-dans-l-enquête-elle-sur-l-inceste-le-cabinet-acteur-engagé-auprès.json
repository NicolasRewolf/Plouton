            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "vw8gmhazaa",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "La judiciarisation de la parole de la victime permet aussi à l'auteur, bien souvent lui-même mineur, de prendre conscience de son acte, de rétablir l'altérité, et de se construire en tant qu'adolescent ou jeune adulte sur des bases plus solides.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "ttesu1kcq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "8q7pax6azg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "En pareil cas, le rôle premier de la justice est de confronter l'auteur à un cadre, d'accompagner et pas simplement de punir.",
              "decorations": [
                {
                  "type": "BOLD"
                }
              ]
            }
          }
        ],
        "paragraphData": {}
      },
      {
