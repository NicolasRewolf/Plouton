            "nodes": [],
            "textData": {
              "text": "Le rôle du droit pénal face aux violences intrafamiliales",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "vlozcxk6nw",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Le droit constitue ici un outil de protection des victimes, en imposant un cadre clair face à des situations où l'émotion et la complexité familiale peuvent freiner l'action.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "j8rnmhgdww",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
