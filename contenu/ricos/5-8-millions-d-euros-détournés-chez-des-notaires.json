                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "l'acquisition de biens par les notaires dans les affaires engagées par leurs clients ;",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
          {
            "type": "LIST_ITEM",
            "id": "tikfivonjg",
            "nodes": [
              {
                "type": "PARAGRAPH",
                "id": "olybhn7w",
                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "le non-respect des conditions de forme lors de l'enregistrement de testaments ;",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
          {
            "type": "LIST_ITEM",
            "id": "ti6e7pvp9a",
            "nodes": [
              {
                "type": "PARAGRAPH",
                "id": "auqvo6tyq",
                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "l'achat et la revente au double de sa valeur du bien d'une octogénaire par une société où apparaît une proche de l'un des notaires.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          }
        ],
