          {
            "type": "LIST_ITEM",
            "id": "otkzb4jxsw",
            "nodes": [
              {
                "type": "PARAGRAPH",
                "id": "4f4mwo6nma",
                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "la perception de commissions à la suite de prêts consentis dans le cadre de négociations ;",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
          {
            "type": "LIST_ITEM",
            "id": "kj97oxkpq",
            "nodes": [
              {
                "type": "PARAGRAPH",
