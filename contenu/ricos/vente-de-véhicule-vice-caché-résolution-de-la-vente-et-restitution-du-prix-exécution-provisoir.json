        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Pour donner au droit d'appel une réelle effectivité, son exercice suspend, en principe, l'exécution de la décision de première instance.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
