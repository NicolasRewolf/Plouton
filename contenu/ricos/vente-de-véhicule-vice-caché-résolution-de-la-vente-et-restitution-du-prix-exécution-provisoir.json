            "nodes": [],
            "textData": {
              "text": "Monsieur G. interjetait appel de la présente décision et assignait parallèlement son créancier en arrêt de l'exécution provisoire.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
