        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "En défense, la partie adverse opposait l'absence de reconnaissance de dette écrite, exigée en principe par l'article 1359 du Code civil pour tout acte juridique portant sur une somme supérieure à 1 500 €.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "beyxgjen3g",
        "nodes": [
          {
            "type": "TEXT",
