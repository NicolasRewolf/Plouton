          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Ce que cette décision enseigne aux concubins",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "kadlurkq8a",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Cette affaire illustre une réalité fréquente : entre concubins, les transferts financiers se font rarement avec reconnaissance de dette. Lorsque la relation se termine, le concubin créancier se retrouve souvent démuni face à un ex-partenaire qui invoque l'absence d'écrit.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "llzqjbym8g",
