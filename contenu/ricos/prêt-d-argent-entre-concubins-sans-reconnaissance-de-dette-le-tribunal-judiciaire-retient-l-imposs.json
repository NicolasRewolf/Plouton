              "text": " ",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "HEADING",
        "id": "xbpfqtwgew",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "La décision : 25 500 € restitués à notre cliente",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "yvkwxtosg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Le Tribunal judiciaire de Bordeaux a fait droit à l'intégralité de la demande de Madame D. Monsieur M a été condamné à lui rembourser la somme de 25 500 euros, assortie des intérêts au taux légal à compter de la mise en demeure de 2017.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
