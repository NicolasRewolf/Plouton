          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Le 4 mai 2021, ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Chahinez Daoud était assassinée à Mérignac",
              "decorations": [
                {
                  "type": "LINK",
                  "linkData": {
                    "link": {
                      "url": "https://www.jplouton-avocat.fr/post/plaidoirie-pour-chahinez",
                      "target": "SELF",
                      "rel": {
                        "nofollow": false,
                        "sponsored": false,
                        "ugc": false
                      }
                    }
                  }
                },
                {
                  "type": "UNDERLINE",
                  "underlineData": true
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " par son conjoint, Mounir B., récemment condamné à la réclusion criminelle à perpétuité par la cour d'assises de la Gironde le 28 mars 2025. Un appel a été interjeté le 4 avril 2025, de sorte que la décision pénale n'est pas définitive.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "e80d8prvkg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
