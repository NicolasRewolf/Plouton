            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "BLOCKQUOTE",
        "id": "7mygk24032",
        "nodes": [
          {
            "type": "PARAGRAPH",
            "id": "yb37324033",
            "nodes": [
              {
                "type": "TEXT",
                "id": "",
                "nodes": [],
                "textData": {
                  "text": "« il n'est pas d'une bonne administration de la justice d'attendre, à ce stade de la présente procédure, qu'il soit définitivement statué sur l'action publique en appel ».",
                  "decorations": []
                }
              }
            ],
            "paragraphData": {
              "indentation": 0
            }
          }
        ],
        "blockquoteData": {
          "indentation": 1
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "nqr27hreg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "fuba0pbkg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Ici, le juge considère au contraire que suspendre l'instance introduite dès avril 2024 ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "porterait atteinte à l'exigence de célérité et aux droits des demandeurs",
              "decorations": [
                {
                  "type": "BOLD"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ", lesquels supportent la charge de la preuve et s'opposent expressément au sursis.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "4zwssvcvvq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "HEADING",
        "id": "dxbhllg0a",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Une décision à contre-courant d'une précédente ordonnance bordelaise",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "x356ywdamw",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "L'importance de cette ordonnance tient aussi à sa portée jurisprudentielle.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "cr1e6nbhoq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "a7ddjoqq1g",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Dans une précédente affaire relative à un féminicide survenu à Bordeaux, ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "la même juridiction avait accueilli une demande de sursis à statuer",
              "decorations": [
                {
                  "type": "BOLD"
                },
                {
                  "type": "LINK",
                  "linkData": {
                    "link": {
                      "url": "https://www.francebleu.fr/nouvelle-aquitaine/gironde-33/bordeaux/feminicide-de-sandra-pla-il-n-y-aura-pas-de-proces-contre-l-etat-avant-celui-en-appel-de-son-meurtrier-2853023",
                      "target": "BLANK",
                      "rel": {
                        "nofollow": false,
                        "sponsored": false,
                        "ugc": false
                      }
                    }
                  }
                },
                {
                  "type": "UNDERLINE",
                  "underlineData": true
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ", estimant que la solution pénale définitive conditionnait l'examen de la responsabilité de l'État.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "zx264egcea",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
