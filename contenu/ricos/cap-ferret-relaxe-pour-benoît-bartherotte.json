            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "HEADING",
        "id": "w7qtneys9g",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Les faits : une intrusion nocturne à la Pointe du Cap Ferret",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2.0
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "niq4esxha",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
