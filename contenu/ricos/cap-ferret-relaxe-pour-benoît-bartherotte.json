        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Dès le lendemain, les deux pêcheurs déposaient plainte contre Monsieur B. pour violences volontaires avec usage d'une arme, en l'espèce un fusil.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "eksq17z6nq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
