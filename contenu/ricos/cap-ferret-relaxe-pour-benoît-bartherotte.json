      {
        "type": "HEADING",
        "id": "aokekeccwg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "La légitime défense renforcée de l'article 122-6 du Code pénal",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2.0
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "ke0iruy9ia",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
