        "id": "0x0ktewecq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Le nom de Chahinez Daoud est aujourd'hui associé à un combat collectif : celui d'une meilleure protection des femmes victimes. Son histoire continue de résonner comme un symbole des manquements dans la ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "lutte contre les violences conjugales",
