          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Brûlée vive à Mérignac par son mari, elle avait pourtant alerté les autorités. Ses signalements n'ont pas suffi à enclencher une réponse adaptée. L'affaire a depuis nourri un débat national sur l'efficacité réelle des dispositifs censés protéger les victimes.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
