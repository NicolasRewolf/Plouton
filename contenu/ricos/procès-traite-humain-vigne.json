        "id": "wi2mwathg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "> « Sur un air de Michel Fugain, 'c'est un beau roman, c'est une belle histoire' entonne ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "maître Julien Plouton, la défense du fils, qui dégonfle les déclarations des 4 parties civiles",
