                "id": "hp1ngt0ua",
                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "les accusations relatives aux conditions de travail reposaient uniquement sur les déclarations des plaignants, sans élément objectif venant les corroborer ;",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
