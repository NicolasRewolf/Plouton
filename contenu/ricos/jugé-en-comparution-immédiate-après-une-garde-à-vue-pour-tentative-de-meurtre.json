        "id": "5kbkdt0ycg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Le Tribunal correctionnel de Bordeaux a tenu compte du contexte de l'affaire et a retenu ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "les circonstances atténuantes et la volonté de réhabilitation",
              "decorations": [
                {
                  "type": "BOLD"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " du prévenu. Les réquisitions du procureur de la République ont été écartées : une peine d'",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "1 an de prison",
              "decorations": [
