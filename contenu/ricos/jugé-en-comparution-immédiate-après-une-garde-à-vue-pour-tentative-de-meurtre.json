        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Les arguments plaidés par Maître Plouton",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2.0
        }
      },
      {
