            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "HEADING",
        "id": "p2gewt7ug",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "4. La critique des réquisitions du parquet",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 3.0
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "c3zfhtagug",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Maître Plouton a critiqué la sévérité des réquisitions, qui demandait ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "trente mois de prison dont dix de sursis probatoire",
              "decorations": [
                {
                  "type": "BOLD"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ". « C'est une peine pour une agression gratuite et sans contexte », a-t-il estimé, regrettant que le parquet prenne « pour argent comptant ce que dit le plaignant » sans considérer les nuances de l'affaire.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "xezeaeaixq",
        "nodes": [
          {
            "type": "TEXT",
