          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Avec la plume subtile de Christophe Hondelatte, le podcast explore la profondeur et la sensibilité des audiences judiciaires. Le journaliste, connu pour son travail de récit judiciaire, restitue les temps forts du procès : interrogatoires, témoignages, plaidoiries et réquisitions.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "qv7u24cmq",
        "nodes": [
          {
