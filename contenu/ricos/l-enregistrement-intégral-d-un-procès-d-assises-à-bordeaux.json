        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Ce procès, tenu à Bordeaux, est au centre du podcast diffusé par Europe 1.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
