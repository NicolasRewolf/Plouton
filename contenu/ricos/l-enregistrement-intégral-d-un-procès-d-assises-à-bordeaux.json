        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Le format permet de saisir la mécanique des assises, depuis la lecture de l'acte d'accusation jusqu'au verdict.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
