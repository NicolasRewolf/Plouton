                      "text": "le préjudice moral.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          }
        ],
        "bulletedListData": {
          "indentation": 0.0
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "tslq6matiq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "mqc4eidtug",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Le fondement de l'action reposait sur la garantie des vices cachés prévue par les articles 1641 et suivants du Code civil.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "bgujesjilq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "HEADING",
        "id": "mqtkv8bdg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "La garantie des vices cachés et la clause de non-garantie",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2.0
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "8bjpbvoi2a",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "L'article 1641 du Code civil impose au vendeur de garantir l'acquéreur contre les défauts cachés de la chose vendue qui la rendent impropre à sa destination. L'article 1643 ajoute que cette garantie est due même lorsque le vendeur ignore l'existence du vice.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "zpz6tlsecq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "gb5rfr2eng",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Toutefois, ce même article 1643 réserve une exception majeure : le vendeur peut s'exonérer de la garantie si une clause de non-garantie a été expressément stipulée dans l'acte de vente. Cette exonération est cependant écartée lorsque le vendeur connaissait le vice au moment de la vente, la mauvaise foi neutralisant la clause.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "hxrpiciloa",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "qgthtjvuma",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "En l'espèce, l'acte de vente comportait une clause de non-garantie des vices cachés au profit du vendeur. La discussion judiciaire s'est donc concentrée sur un point unique : le vendeur avait-il connaissance du vice affectant la charpente ?",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "qjfjugg7q",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "HEADING",
        "id": "o755lukiea",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "La stratégie de défense du Cabinet Julien Plouton",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2.0
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "v0guftymg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Pour faire échec à la clause de non-garantie, l'acquéreur soutenait que le vendeur ne pouvait ignorer l'état dégradé de la charpente. Il s'appuyait notamment sur les travaux d'isolation et de pose d'un faux-plafond réalisés par le vendeur, qui auraient nécessairement révélé la vétusté de la structure.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "xnifxkjrmq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "uyqkkdvpsw",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Le Cabinet a opposé à cette argumentation la bonne foi du vendeur et l'absence de preuve d'une connaissance effective du vice. La défense a démontré que les travaux invoqués par l'acquéreur ne permettaient pas, à eux seuls, d'établir que le vendeur avait eu une vision claire de l'état de la charpente.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "n83cwnc2w",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "elpe3d8dtg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Sur cette base, le Cabinet a sollicité l'application pleine et entière de la clause de non-garantie stipulée dans l'acte authentique.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "y70ibllw",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "HEADING",
        "id": "5gs4ib7qxa",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "La décision du Tribunal de Grande Instance de Périgueux",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2.0
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "xpgnwwcrra",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Par jugement du 14 mai 2019, le Tribunal de Grande Instance de Périgueux a suivi l'argumentation de la défense. Il a jugé que la preuve de la connaissance du vice par le vendeur n'était pas rapportée et que la clause de non-garantie devait donc recevoir application.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "id5rdljcha",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "seea1yxtnq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "L'acquéreur a été débouté de l'intégralité de ses demandes. Aucune indemnisation, sur les plus de 50 000 euros sollicités, n'a été mise à la charge du vendeur.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "mnqam6lnyq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "HEADING",
        "id": "omuywny5rg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Ce que cette décision rappelle aux vendeurs immobiliers",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2.0
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "5pdxymgvyq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Cette affaire illustre la portée concrète d'une clause de non-garantie des vices cachés dans une vente immobilière entre particuliers. Trois enseignements pratiques se dégagent :",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "6jfsexcmnq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "BULLETED_LIST",
        "id": "epjhvbqwia",
        "nodes": [
          {
            "type": "LIST_ITEM",
            "id": "dwsms8xozw",
            "nodes": [
              {
                "type": "PARAGRAPH",
                "id": "f4ukdd7yyw",
                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "la clause de non-garantie reste un outil de protection efficace pour le vendeur non professionnel, à condition d'être correctement rédigée dans l'acte ;",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
          {
            "type": "LIST_ITEM",
            "id": "cewr4y6cvg",
            "nodes": [
              {
                "type": "PARAGRAPH",
                "id": "g2dcwmakha",
                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "la charge de la preuve de la connaissance du vice par le vendeur pèse sur l'acquéreur qui souhaite neutraliser la clause ;",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
          {
            "type": "LIST_ITEM",
            "id": "vkcan0imjw",
            "nodes": [
              {
                "type": "PARAGRAPH",
                "id": "azmeeovcvw",
                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "des travaux antérieurs réalisés par le vendeur ne suffisent pas, à eux seuls, à caractériser sa mauvaise foi.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          }
        ],
        "bulletedListData": {
          "indentation": 0.0
        }
      },
