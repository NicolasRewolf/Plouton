          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Le Cabinet Julien Plouton intervient régulièrement en défense des vendeurs et des acquéreurs dans les contentieux post-vente immobilière fondés sur les articles 1641 et suivants du Code civil.",
              "decorations": []
            }
          }
        ],
