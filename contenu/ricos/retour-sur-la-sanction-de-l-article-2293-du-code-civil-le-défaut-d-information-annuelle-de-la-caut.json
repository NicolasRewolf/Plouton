        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Dans un arrêt du 10 octobre 2019, la première chambre civile de la Cour de cassation a fait application de ce texte.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "emnkvpu8rw",
        "nodes": [
          {
            "type": "TEXT",
