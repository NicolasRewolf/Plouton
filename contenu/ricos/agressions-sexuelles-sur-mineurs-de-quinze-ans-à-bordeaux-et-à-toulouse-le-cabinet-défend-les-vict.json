                  "type": "BOLD"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ". À défaut de respect de cette obligation de soin, Monsieur R. s'expose à une peine d'emprisonnement d'un an.",
