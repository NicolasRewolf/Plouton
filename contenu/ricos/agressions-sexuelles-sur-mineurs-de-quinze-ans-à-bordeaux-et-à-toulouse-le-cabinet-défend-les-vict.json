        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Il avait en revanche reconnu des « embrassades » ainsi que des caresses sur le corps et les parties intimes de Madame P., mais demeurait dans la minimisation de l'ensemble des actes qui lui étaient reprochés.",
