        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "La veille, le 21 novembre 2007, en milieu de soirée, les douaniers tentent d'intercepter une Mercedes, une Phaeton et une Audi A3 à hauteur de Benesse-Marenne, puis de Lilaire. En vain.",
              "decorations": []
            }
