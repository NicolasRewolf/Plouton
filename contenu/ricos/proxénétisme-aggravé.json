        "id": "wrtycziiq",
        "nodes": [
          {
            "type": "LIST_ITEM",
            "id": "pmripxxyqa",
            "nodes": [
              {
                "type": "PARAGRAPH",
                "id": "dmcgllndwq",
                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "Dix-huit mois de prison dont quatorze avec sursis et une amende de 10 000 euros contre les deux « sisters »",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
          {
            "type": "LIST_ITEM",
            "id": "zfhmqug2ra",
            "nodes": [
              {
                "type": "PARAGRAPH",
                "id": "iyy4ndiwyg",
                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "Un an avec sursis contre le « tonton »",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          }
        ],
        "bulletedListData": {
          "indentation": 0.0
        }
      },
      {
