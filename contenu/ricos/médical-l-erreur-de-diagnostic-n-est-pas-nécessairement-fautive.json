            "nodes": [],
            "textData": {
              "text": "Le principe : l'erreur de diagnostic n'est pas fautive en soi",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "1ybdyszlfq",
