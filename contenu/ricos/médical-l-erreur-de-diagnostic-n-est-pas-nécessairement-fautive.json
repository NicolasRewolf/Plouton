          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Un individu s'évanouit et les médecins appelés sur les lieux diagnostiquent un malaise vagal. Quelques heures plus tard, à son domicile, il ressent des céphalées et est atteint de vomissements.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
