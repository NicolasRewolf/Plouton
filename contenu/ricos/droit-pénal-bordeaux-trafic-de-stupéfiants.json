          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Les policiers étaient remontés jusqu'à lui par le biais d'écoutes téléphoniques, en enquêtant sur un autre trafic. À ses côtés dans le box des détenus se trouvent :",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
