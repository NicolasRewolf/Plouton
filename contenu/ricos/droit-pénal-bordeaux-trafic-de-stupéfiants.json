            "nodes": [],
            "textData": {
              "text": "Depuis lundi, 29 détenus sont jugés dans le cadre d'un trafic de résine de cannabis et de cocaïne devant le tribunal correctionnel de Bordeaux. Le parquet, représenté par M. Bellet, requiert jusqu'à 7 ans de prison ferme. Christine Morice préside l'audience.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "q34zgxglqa",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
