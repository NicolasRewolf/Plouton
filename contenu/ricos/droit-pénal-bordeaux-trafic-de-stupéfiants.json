        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "cpxangpag",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Il joue au poker, roule en cabriolet, jongle avec les téléphones portables. Il circule beaucoup, surtout en direction de l'Espagne, et utilise des chambres d'hôtel comme positions de repli. Il est accusé de vendre le « shit » au kilo. Tel est le profil de Grégory Fabre, alias « Greg », jugé depuis lundi pour trafic de stupéfiants avec 28 autres prévenus.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
