                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "À la suite de son incarcération, notre client avait contacté des amis à l'extérieur pour tenter de récupérer de l'argent issu du trafic entreposé à son domicile.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
