              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "HEADING",
        "id": "wgu7s2mwgg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "La décision : cinq ans au lieu de huit, le tribunal redonne au dossier sa juste proportion",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2.0
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "ydcgmxaqiw",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Le Tribunal a paru animé par ce souci de cohérence. Il a écarté la construction intellectuelle, certes attrayante mais injustifiée, du parquet et a redonné à ce dossier de trafic de cocaïne sa juste proportion.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
