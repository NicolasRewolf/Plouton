          {
            "type": "LIST_ITEM",
            "id": "7iwbzdb9qg",
            "nodes": [
              {
                "type": "PARAGRAPH",
                "id": "ttipzubmtw",
                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "Il leur avait transféré ses contacts dans l'espoir de toucher quelques commissions, car il se trouvait dans un dénuement total en détention.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
          {
            "type": "LIST_ITEM",
            "id": "ipbkrh460a",
            "nodes": [
              {
                "type": "PARAGRAPH",
                "id": "jz15u3ql0a",
                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "Ceux que le parquet présentait comme ses fidèles lieutenants avaient en réalité profité de son incarcération pour développer leur propre trafic, préexistant, en reprenant une partie de sa clientèle.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
          {
            "type": "LIST_ITEM",
            "id": "kgpembw71w",
            "nodes": [
              {
                "type": "PARAGRAPH",
                "id": "aom3ydsmdw",
                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "Notre client ne touchait qu'une petite commission, le prix de revente étant majoré de quelques euros par gramme de cocaïne.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
          {
            "type": "LIST_ITEM",
            "id": "ol2avxdcq",
            "nodes": [
              {
                "type": "PARAGRAPH",
                "id": "nfc4ag9kww",
                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "Contrairement aux affirmations du parquet, aucune menace ni pression n'apparaissait dans les échanges : les interlocuteurs apparaissaient comme des amis, non comme des subordonnés.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          }
        ],
        "bulletedListData": {
