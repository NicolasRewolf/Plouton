                  "fontWeightValue": 700
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " de Monsieur L. pour l'ensemble des chefs de prévention (escroquerie et pratiques commerciales trompeuses).",
              "decorations": []
            }
          }
        ],
        "paragraphData": {
          "textStyle": {
            "textAlignment": "AUTO"
          }
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "y45sf2496",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Les juges ont reconnu que la preuve de sa participation personnelle aux ventes frauduleuses n'était pas rapportée et que sa qualité de simple salarié exécutant ne suffisait pas à caractériser l'intention délictueuse nécessaire à une condamnation.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {
          "textStyle": {
            "textAlignment": "AUTO"
          }
