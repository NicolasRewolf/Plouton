          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Le Tribunal Correctionnel a suivi notre argumentation. Dans sa décision du 4 novembre, il a prononcé la ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "relaxe",
