                          "fontWeightValue": 700
                        }
                      ]
                    }
                  },
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": " On ne peut pas condamner un salarié \"par contamination\" simplement parce que son employeur a mis en place un système frauduleux. Il faut prouver sa participation active et consciente.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {
