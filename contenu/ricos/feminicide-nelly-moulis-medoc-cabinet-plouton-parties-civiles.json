      {
        "type": "PARAGRAPH",
        "id": "nwcipzstfq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Ce drame survient dans un contexte particulièrement préoccupant. Selon la députée PS Pascale Got, « sur les deux féminicides que nous avons eus dans le département depuis le début de l'année, à chaque fois, c'était avec un récidiviste ».",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
