      {
        "type": "PARAGRAPH",
        "id": "bjbrk8svhg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Le 21 juillet 2025, une centaine de personnes s'est rassemblée devant la mairie de Castelnau-de-Médoc pour rendre hommage à Nelly. ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Conchita Cimbron",
              "decorations": [
                {
                  "type": "BOLD"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ", présidente de l'association ACV2F qui avait appelé à ce rassemblement, a déclaré : « C'est terrible. Il ne faut pas que ces crimes soient banalisés ou oubliés. C'est des femmes qui sont tuées parce qu'elles sont des femmes. »",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "osmf3llccg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
              "decorations": []
            }
