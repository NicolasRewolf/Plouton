          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Le recours contre le tiers responsable d'un accident du travail combine droit de la sécurité sociale et règles de la responsabilité civile. Pour une prise en charge experte des ",
              "decorations": []
            }
          },
          {
