        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Ce que cette affaire illustre en matière de responsabilité médicale",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "fbaliggaq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "La décision de la Cour d'appel de Bordeaux constitue une avancée significative pour Madame B. Elle illustre l'importance, pour les victimes de fautes médicales, d'engager rapidement une expertise judiciaire et de solliciter des provisions tout au long de la procédure, plutôt que d'attendre la consolidation pour faire valoir leurs droits.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
