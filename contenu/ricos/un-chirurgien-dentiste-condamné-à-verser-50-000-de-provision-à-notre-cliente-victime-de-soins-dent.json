                "id": "q87ya6flmq",
                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "Réponse amiable partielle",
                      "decorations": [
                        {
                          "type": "BOLD"
                        }
                      ]
                    }
                  },
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": " : une première provision a été versée à Madame B., insuffisante au regard de l'ampleur des soins nécessaires.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
          {
            "type": "LIST_ITEM",
