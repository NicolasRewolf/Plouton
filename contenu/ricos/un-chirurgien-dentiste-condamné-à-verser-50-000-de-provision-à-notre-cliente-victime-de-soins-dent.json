                  "type": "BOLD"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ". Concrètement, elle lui permet de financer la poursuite de ses soins dentaires dans l'attente de la consolidation de son état de santé, étape indispensable avant que le juge ne puisse statuer sur l'indemnisation définitive de ses préjudices.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
