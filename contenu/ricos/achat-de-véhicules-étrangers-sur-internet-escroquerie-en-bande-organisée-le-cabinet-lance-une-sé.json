                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "centraliser l'enquête au sein de la JIRS de Bordeaux, compétente en matière de criminalité organisée ;",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
