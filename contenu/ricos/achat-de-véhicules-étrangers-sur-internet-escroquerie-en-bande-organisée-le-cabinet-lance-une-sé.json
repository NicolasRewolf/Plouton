        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Nous avons fait le choix d'une plainte unique regroupant l'ensemble des victimes identifiées, plutôt que de plaintes individuelles dispersées. Ce regroupement poursuit trois objectifs :",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "dr3s5exhjw",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
