        "id": "4kxtj6omoq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "L'affaire illustre la sophistication des escroqueries en ligne ciblant les consommateurs sur le marché automobile, et le rôle déterminant des établissements bancaires dans la chaîne de blanchiment.",
              "decorations": []
            }
