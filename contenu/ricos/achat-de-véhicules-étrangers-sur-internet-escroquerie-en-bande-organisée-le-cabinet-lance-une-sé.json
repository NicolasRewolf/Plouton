        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Une réponse judiciaire forte attendue",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2
        }
      },
      {
