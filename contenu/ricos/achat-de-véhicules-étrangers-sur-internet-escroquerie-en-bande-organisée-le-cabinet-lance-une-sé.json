        "id": "8pqitu2cea",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "L'action collective menée par le cabinet devant la JIRS de Bordeaux",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2
        }
      },
      {
