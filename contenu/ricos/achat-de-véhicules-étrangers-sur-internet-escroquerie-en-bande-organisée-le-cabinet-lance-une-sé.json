                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "mutualiser les éléments de preuve (échanges, virements, captures d'écran, flux bancaires) ;",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
