        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Chaque dossier pénal est unique et requiert une approche sur mesure. L'avocat pénaliste analyse les faits, évalue les preuves, et anticipe les arguments de l'accusation pour bâtir une défense robuste. Il veille également à mettre en avant des éléments contextuels ou personnels susceptibles d'influer sur l'appréciation des juges.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
