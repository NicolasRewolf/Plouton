                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ". Ils constataient qu'il détenait dans sa sacoche plusieurs grammes de cocaïne, cannabis et MDMA.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "wqnpjd7mtq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
