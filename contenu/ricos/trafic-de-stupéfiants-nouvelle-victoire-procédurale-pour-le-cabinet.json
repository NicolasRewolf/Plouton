                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ". Un nouvel équipage de la BAC se rendait à l'adresse indiquée et procédait à l'interpellation d'une jeune femme en possession de drogues qui servait à la fois de ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "nourrice et de livreur de stupéfiants",
