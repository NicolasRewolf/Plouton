            "textData": {
              "text": "téléphone portable et son domicile avaient été perquisitionnés",
              "decorations": [
                {
                  "type": "BOLD"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ". L'enquête avait permis de mettre en évidence qu'il ",
              "decorations": []
