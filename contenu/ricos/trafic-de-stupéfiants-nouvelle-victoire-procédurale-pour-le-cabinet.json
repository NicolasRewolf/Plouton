        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Ce dernier était de nouveau contrôlé et interpellé moins d'un mois plus tard. Il était à nouveau placé en garde à vue et ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
