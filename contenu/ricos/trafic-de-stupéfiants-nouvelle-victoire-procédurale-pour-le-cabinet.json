        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Les enquêteurs décidaient alors de procéder à son contrôle puis pratiquaient sur sa personne une ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "palpation de sécurité",
              "decorations": [
