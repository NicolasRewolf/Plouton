        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Il était interpellé et placé en garde à vue. Les enquêteurs constataient alors que son téléphone recevait des messages PUSH UP qui faisaient état d'une ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
