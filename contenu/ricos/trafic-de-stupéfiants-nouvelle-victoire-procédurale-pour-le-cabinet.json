          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Nous avions assisté le 30 septembre dernier un jeune homme qui ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "comparaissait devant le tribunal correctionnel pour des faits de trafic de stupéfiants",
              "decorations": [
                {
                  "type": "BOLD"
                },
                {
                  "type": "LINK",
                  "linkData": {
                    "link": {
                      "url": "https://www.jplouton-avocat.fr/defense-penale/trafic-de-stupefiant",
                      "target": "SELF",
                      "rel": {
                        "nofollow": false,
                        "sponsored": false,
                        "ugc": false
                      }
                    }
                  }
                },
                {
                  "type": "UNDERLINE",
                  "underlineData": true
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ". Âgé d'une vingtaine d'années, il avait été interpellé dans le courant de l'été dans le centre-ville de Bordeaux et ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "placé sous contrôle judiciaire",
              "decorations": [
                {
                  "type": "BOLD"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " dans l'attente de son jugement.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "u71udfmsa",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
