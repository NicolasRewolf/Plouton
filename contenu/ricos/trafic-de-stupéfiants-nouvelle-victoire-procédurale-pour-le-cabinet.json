          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Face aux institutions judiciaires, l'avocat pénaliste est un rempart pour garantir le respect des droits de son client. Que ce soit en garde à vue, lors des auditions, ou à l'audience, il veille à ce que la procédure respecte les principes d'équité, de présomption d'innocence et de proportionnalité des mesures prises.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
