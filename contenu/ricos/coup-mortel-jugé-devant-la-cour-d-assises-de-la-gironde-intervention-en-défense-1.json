          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ". Elle s'était alors convaincue qu'elle allait perdre la vie et laisser orphelin son petit garçon de huit ans.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
