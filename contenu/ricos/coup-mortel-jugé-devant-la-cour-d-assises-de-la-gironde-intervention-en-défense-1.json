        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "L'accusée encourait 20 années de réclusion criminelle. Les débats, sereins et empreints d'une émotion palpable, ont occupé la Cour pendant près de trois jours.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
