          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Les débats à l'audience devaient notamment déterminer le statut exact de ces revendeurs hollandais :",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
