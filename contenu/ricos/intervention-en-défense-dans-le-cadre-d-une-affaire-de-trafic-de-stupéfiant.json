            "textData": {
              "text": "Tribunal correctionnel de Bordeaux, audience des 4 et 5 juillet 2017",
              "decorations": [
                {
                  "type": "ITALIC"
                }
              ]
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "qsv0slag",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
