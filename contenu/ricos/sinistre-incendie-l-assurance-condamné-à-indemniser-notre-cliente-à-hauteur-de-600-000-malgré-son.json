        "id": "vqqmqz1ka",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Allianz en tirait deux conséquences :",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
