          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " La 6ᵉ chambre civile a jugé, le 11 juillet 2024, que l'assureur ne démontrait pas que la fausse déclaration avait modifié le risque assuré (RG n°22/06153).",
              "decorations": []
            }
          }
        ],
