                    "textData": {
                      "text": "la fausse déclaration intentionnelle entraînait la nullité du contrat d'assurance habitation ;",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
          {
            "type": "LIST_ITEM",
            "id": "n4kwju0nga",
            "nodes": [
              {
