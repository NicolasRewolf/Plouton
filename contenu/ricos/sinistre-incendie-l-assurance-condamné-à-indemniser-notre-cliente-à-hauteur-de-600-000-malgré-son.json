        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Notre stratégie : contester non pas la déclaration, mais ses conséquences",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "ganhe871dg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Nous avons construit notre défense sur deux axes complémentaires.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "orjdhry2gw",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
