        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Le 25 décembre 2014, alors que les enfants de Monsieur A. déballent leurs cadeaux à leur domicile, leur joie est brutalement interrompue. Avec leur mère, ils subissent l'assaut d'une horde de 4 personnes venues les dépouiller des cadeaux de Noël et tout saccager sur leur passage.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "nu7lom5krq",
        "nodes": [
          {
            "type": "TEXT",
