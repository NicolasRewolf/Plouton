        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Arrivé sur place, Monsieur A. ne peut que constater l'étendue des dégâts : de nombreux bris de verre et des objets jonchent le sol, tandis que les enfants et leur mère sont tapis à l'étage, pétrifiés.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
