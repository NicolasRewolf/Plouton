        "id": "ufmyd3dg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Prise de panique, la mère des enfants les emmène à l'étage et prévient leur père, Monsieur A., dont elle est séparée depuis plusieurs années mais avec qui elle entretient toujours des rapports cordiaux.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "07msnhybw",
