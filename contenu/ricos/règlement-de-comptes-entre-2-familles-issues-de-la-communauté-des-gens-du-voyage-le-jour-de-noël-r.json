            "nodes": [],
            "textData": {
              "text": "La mère des enfants reconnaît parfaitement les auteurs de l'intrusion : il s'agit de membres de sa propre famille, dont sa sœur, avec qui elle est en froid depuis plusieurs années.",
              "decorations": []
            }
          }
        ],
