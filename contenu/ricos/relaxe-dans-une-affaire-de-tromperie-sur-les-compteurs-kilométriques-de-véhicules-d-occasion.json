                        }
                      ]
                    }
                  },
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": " : le 2 mai 2015, un véhicule de marque BMW a été contrôlé à Sainte-Foy-la-Grande. Les explications fournies par le conducteur sur la propriété du véhicule présentaient des incohérences.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
          {
            "type": "LIST_ITEM",
            "id": "ooqbp4v2ug",
