                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "Enquête approfondie",
                      "decorations": [
                        {
                          "type": "BOLD"
                        }
                      ]
                    }
                  },
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": " : les investigations qui ont suivi ont établi que ce véhicule avait été vendu deux fois en avril 2015. Deux frères, nos clients, déjà connus pour des faits similaires, ont été identifiés comme principaux suspects.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
          {
