                        }
                      ]
                    }
                  },
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": " : certaines démarches procédurales n'ont pas respecté les droits fondamentaux de la défense. Des éléments de preuve essentiels n'ont pas été communiqués en temps voulu, privant la défense de la possibilité de préparer une réponse adéquate.",
                      "decorations": []
                    }
                  }
                ],
