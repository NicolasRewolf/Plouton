                        }
                      ]
                    }
                  },
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": " : le dossier a été divisé en plusieurs sous-dossiers (investigations générales, réquisitions, aspects financiers, implications des protagonistes, véhicules suspects). Un volume important de véhicules achetés puis rapidement revendus après modification des compteurs a été identifié.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
