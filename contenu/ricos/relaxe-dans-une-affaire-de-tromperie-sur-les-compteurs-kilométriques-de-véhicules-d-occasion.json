                      "decorations": [
                        {
                          "type": "BOLD"
                        }
                      ]
                    }
                  },
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": " : les investigations ont été conduites en lien avec le procureur de la République, avec des réquisitions auprès de divers services (Pôle Emploi, Tribunal de Commerce, etc.) pour analyser les flux financiers.",
                      "decorations": []
                    }
