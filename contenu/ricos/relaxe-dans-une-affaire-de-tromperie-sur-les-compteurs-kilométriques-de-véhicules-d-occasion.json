        "id": "gjbbnjnqzg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Le client était poursuivi devant le tribunal correctionnel pour le délit de tromperie, prévu et réprimé par l'article L441-1 du Code de la consommation :",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "b8m5lolciw",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
