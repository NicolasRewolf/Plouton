              "text": "Découvrez l'interview de Maitre Julien PLOUTON sur France3 Nouvelle-Aquitaine",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2.0,
          "textStyle": {
            "textAlignment": "AUTO"
          }
        }
      },
      {
        "type": "VIDEO",
        "id": "9zh8a6972819",
