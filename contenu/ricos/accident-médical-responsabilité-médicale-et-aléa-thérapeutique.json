                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "en cas de troubles particulièrement graves dans les conditions d’existence du patient.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              },
              {
                "type": "PARAGRAPH",
                "id": "7uh5v7811",
