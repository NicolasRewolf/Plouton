            "textData": {
              "text": "Le Figaro",
              "decorations": [
                {
                  "type": "ITALIC"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " — qui ont perdu plusieurs dizaines à plusieurs centaines de milliers d'euros. Notre approche : une plainte étayée, transmise à une cellule spécialisée du parquet financier, pour maximiser les chances de retrouver les escrocs et de récupérer les fonds détournés.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
