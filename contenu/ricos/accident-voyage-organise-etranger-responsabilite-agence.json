                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "Le Comité d'Entreprise (CSE) est souvent hors de cause :",
                      "decorations": [
                        {
                          "type": "BOLD",
                          "fontWeightValue": 700
                        }
                      ]
                    }
                  },
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": " Dans cette affaire, le Tribunal a confirmé que le CE, agissant comme simple intermédiaire sans but lucratif, n'était pas responsable.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {
                  "textStyle": {
                    "textAlignment": "AUTO"
