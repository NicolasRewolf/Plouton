                    "nodes": [],
                    "textData": {
                      "text": "L'agence est votre interlocuteur :",
                      "decorations": [
                        {
                          "type": "BOLD",
                          "fontWeightValue": 700
                        }
                      ]
                    }
                  },
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": " Vous n'avez pas à poursuivre le chauffard ou l'hôtel à l'autre bout du monde. L'agence française est responsable de plein droit.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {
                  "textStyle": {
                    "textAlignment": "AUTO"
                  }
                }
