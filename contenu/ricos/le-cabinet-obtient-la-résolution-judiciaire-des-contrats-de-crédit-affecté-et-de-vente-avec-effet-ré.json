        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "La banque avait nécessairement connaissance des litiges qui ne cessaient de croître autour des installations photovoltaïques, étant elle-même partenaire habituel de nombreuses sociétés exerçant cette activité.",
              "decorations": []
