            "textData": {
              "text": "L'attitude du pire : un accident aux conséquences potentiellement dramatiques ",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2.0,
          "textStyle": {
            "textAlignment": "AUTO"
          }
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "n4z5e1487",
        "nodes": [],
        "paragraphData": {
          "textStyle": {
