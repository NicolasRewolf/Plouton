            "textData": {
              "text": "\n",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Le parquet avait requis une peine de six mois de prison, dont trois avec sursis et mise à l'épreuve, ainsi qu'un mandat de dépôt.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {
          "textStyle": {
            "textAlignment": "AUTO"
          }
        }
      },
