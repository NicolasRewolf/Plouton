              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Face aux accusations, l'avocate du prévenu, Me Stéphanie Fougeras, a plaidé l'état de choc et de désorientation, arguant que son client avait surtout « besoin de soins ».",
              "decorations": []
            }
          }
        ],
        "paragraphData": {
          "textStyle": {
            "textAlignment": "AUTO"
          }
        }
      },
