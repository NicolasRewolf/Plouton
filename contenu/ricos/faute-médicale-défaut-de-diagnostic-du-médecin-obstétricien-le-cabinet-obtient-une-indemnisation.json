        "id": "3nivzqtnag",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Tribunal de Grande Instance d'ANGOULEME, 1ère Chambre civile, 21 juin 2018, RG n°14/00384",
              "decorations": [
                {
                  "type": "ITALIC"
                }
              ]
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "ojfzd2wxfg",
        "nodes": [
          {
            "type": "TEXT",
