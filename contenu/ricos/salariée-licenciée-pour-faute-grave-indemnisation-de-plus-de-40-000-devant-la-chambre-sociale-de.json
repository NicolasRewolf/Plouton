        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "La Cour rappelle également qu'il appartient à l'employeur de rapporter la preuve que les griefs allégués dans le cadre de l'avertissement sont établis. À défaut d'éléments suffisamment probants, l'avertissement doit être annulé.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "opijw4tbaw",
