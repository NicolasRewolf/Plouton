        "id": "idoqqncwq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "« Ils n'ont fait de mal à personne. Ils ont travaillé et passé des diplômes en prison pour se reconstruire », plaide l'avocat. Verdict aujourd'hui.",
              "decorations": []
            }
          }
        ],
