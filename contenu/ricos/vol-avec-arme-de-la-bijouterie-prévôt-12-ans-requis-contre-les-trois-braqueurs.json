              "text": " ",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "HEADING",
        "id": "utigawt2fw",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "La plaidoirie de Me Julien Plouton : absence de violence et reconstruction",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2.0
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "nafyubl1oq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Me Julien Plouton",
              "decorations": [
                {
                  "type": "BOLD"
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " plaide pour Redouane E K., qui a reconnu les faits. La défense choisit d'insister sur deux éléments : l'absence totale de violence physique lors du braquage et la personnalité rassurante de l'accusé.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "pcjcqolvig",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " ",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
