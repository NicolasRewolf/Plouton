                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "son ADN retrouvé sur une chaussure présente dans le véhicule ;",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
          {
            "type": "LIST_ITEM",
            "id": "gfzgipjuyg",
            "nodes": [
