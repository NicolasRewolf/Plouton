        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "« Nous ne sommes plus dans des coïncidences », conclut l'avocat général.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "3yxxooo5nq",
        "nodes": [
          {
