                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "l'empreinte de son index gauche relevée sur un téléphone découvert dans le coffre de la Peugeot 206 utilisée par Salah B. et Azzedine B. ;",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
          {
            "type": "LIST_ITEM",
            "id": "vwraa85ewg",
