      {
        "type": "PARAGRAPH",
        "id": "xtaivwdera",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Le montant des loyers est naturellement fixé sur la base des documents comptables présentés par l'homme d'affaires. Pour doper la fréquentation, Sybil M. crée un site internet à ses frais, fait de la publicité, démarche des tour-opérateurs français.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "t2qtrtscfg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
