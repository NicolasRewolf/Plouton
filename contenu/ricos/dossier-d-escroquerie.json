        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Le montage : location-gérance puis cession",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2.0
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "ggszmow6w",
        "nodes": [
          {
            "type": "TEXT",
