            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "ec1bkedeia",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "« Cet homme n'a jamais véritablement eu l'intention de céder son hôtel », déplore l'avocat. « Les faits dont a été victime Madame Marquet sont susceptibles de revêtir la qualification d'escroquerie, ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "abus de confiance",
              "decorations": [
                {
                  "type": "LINK",
                  "linkData": {
