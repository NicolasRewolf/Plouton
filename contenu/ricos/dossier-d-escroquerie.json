            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Récemment, par le biais de son conseil bordelais Me Julien Plouton, Sybil M. a porté plainte auprès du procureur de la République de Bordeaux.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "s892bg8nwq",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
