        ],
        "paragraphData": {}
      },
      {
        "type": "BULLETED_LIST",
        "id": "xxpsphctfw",
        "nodes": [
          {
            "type": "LIST_ITEM",
            "id": "3bkgasxa",
            "nodes": [
              {
                "type": "PARAGRAPH",
                "id": "vrbhbvfdaa",
                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "Une phase de location-gérance d'une durée d'un an",
                      "decorations": [
                        {
                          "type": "BOLD"
                        }
                      ]
                    }
                  },
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": ", durant laquelle Sybil M. perçoit l'intégralité des revenus générés par l'établissement et doit en contrepartie s'acquitter d'un loyer mensuel de 10 000 dollars américains. À titre de dépôt de garantie, elle verse deux loyers et une caution de 20 000 dollars.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          },
          {
            "type": "LIST_ITEM",
            "id": "67dlsiikia",
            "nodes": [
              {
                "type": "PARAGRAPH",
                "id": "tawo1gg11a",
                "nodes": [
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "Puis une phase de cession pure et simple",
                      "decorations": [
                        {
                          "type": "BOLD"
                        }
                      ]
                    }
                  },
                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": " de l'hôtel, une option d'achat ayant été accordée dans le contrat de location-gérance.",
                      "decorations": []
                    }
                  }
                ],
                "paragraphData": {}
              }
            ]
          }
        ],
        "bulletedListData": {
          "indentation": 0.0
