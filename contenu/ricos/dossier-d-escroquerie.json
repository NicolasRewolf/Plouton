        "id": "7bhzuhs5ew",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Faux documents et soupçons de blanchiment",
              "decorations": []
            }
          }
        ],
        "headingData": {
          "level": 2.0
        }
      },
      {
        "type": "PARAGRAPH",
        "id": "xjbjxb1e4w",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
