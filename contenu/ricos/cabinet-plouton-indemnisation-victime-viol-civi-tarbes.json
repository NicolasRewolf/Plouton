            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ", âgée de 17 ans, travaille dans un supermarché des Hautes-Pyrénées. Son responsable, ",
              "decorations": []
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "Monsieur AC.",
              "decorations": [
                {
