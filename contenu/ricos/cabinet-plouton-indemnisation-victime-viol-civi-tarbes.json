                  "fontWeightValue": 700
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ", avocat en droit pénal des victimes à Bordeaux, l’accompagne dans cette démarche essentielle devant la ",
