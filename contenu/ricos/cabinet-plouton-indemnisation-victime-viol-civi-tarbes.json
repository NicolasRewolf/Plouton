              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": ". Un geste qui, tout en scellant le dossier pénal, laisse la victime face à un double vide : celui du procès et celui de la reconnaissance judiciaire.",
              "decorations": []
            }
