                  "fontWeightValue": 700
                }
              ]
            }
          },
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": " à la victime. Cette somme, au-delà de son aspect financier, marque une première étape symbolique : ",
