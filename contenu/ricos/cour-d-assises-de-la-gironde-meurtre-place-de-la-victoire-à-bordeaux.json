            "nodes": [],
            "textData": {
              "text": "Christophe Hippolyte n'a pas tenté de s'enfuir. Il a toujours reconnu avoir été l'auteur des coups. Il a cependant invoqué la ",
              "decorations": []
            }
          },
          {
