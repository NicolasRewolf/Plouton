        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "L'accusé, Christophe Hippolyte, un autre Martiniquais de 28 ans, a été reconnu coupable à l'issue des débats.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
