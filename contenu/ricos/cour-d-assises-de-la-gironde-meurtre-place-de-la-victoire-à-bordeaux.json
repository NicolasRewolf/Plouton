        "paragraphData": {}
      },
      {
        "type": "PARAGRAPH",
        "id": "vdlwc1yocg",
        "nodes": [
          {
            "type": "TEXT",
            "id": "",
            "nodes": [],
            "textData": {
              "text": "La bagarre dégénère. Jean-Denis Cory, qui est ivre, blesse Christophe Hippolyte à l'arcade sourcilière avec un tesson de bouteille ramassé près d'une poubelle. Il le menace ensuite avec une fourchette à poulet prise dans la cuisine du restaurant Le Chicken Station, situé dans la même rue.",
              "decorations": []
            }
          }
        ],
        "paragraphData": {}
      },
      {
