                  {
                    "type": "TEXT",
                    "id": "",
                    "nodes": [],
                    "textData": {
                      "text": "Christophe Hippolyte, un solide gaillard affichant 1,86 m à la toise, est accusé par l'un d'eux d'avoir dérobé un téléphone portable. Il s'en défend, puis s'en va.",
                      "decorations": []
